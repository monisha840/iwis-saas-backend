# ─── Al-Shifa Backend — Environment Configuration ────────────────────────────
# Copy this file to .env and fill in values. Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development   # development | production | test

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/alshifa?schema=public"
# Set to 'true' to log every Prisma query (local dev only — very verbose)
DB_LOG_QUERIES=false

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET="your_strong_jwt_secret_min_32_chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ── Frontend & CORS ───────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
# Comma-separated list of additional allowed origins (optional)
ALLOWED_ORIGINS=""

# ── Redis (cache + Bull queues) ───────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Notification Queues ───────────────────────────────────────────────────────
# n8n webhook — called by the Bull queue worker, not inline in requests
N8N_WEBHOOK_URL="https://your-n8n-instance.com/webhook/..."
WEBHOOK_SECRET="your-webhook-secret"
QUEUE_CONCURRENCY=5
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=5000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@alshifa.health

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@alshifa.health

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_MAX_MB=10
UPLOAD_DIR=uploads

# ── CI/CD — set in GitHub Actions secrets, not here ─────────────────────────
# RENDER_DEPLOY_HOOK_URL=          # Production Render deploy hook
# RENDER_STAGING_DEPLOY_HOOK_URL=  # Staging Render deploy hook
