# ─── Al-Shifa Backend — Environment Configuration ────────────────────────────
# Copy this file to .env and fill in values. Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development   # development | production | test

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/alshifa?schema=public"
# Connection pool tuning (appended to DATABASE_URL at runtime)
DB_POOL_SIZE=10          # max connections per Prisma engine instance
DB_POOL_TIMEOUT=10       # seconds to wait for a free connection before erroring

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET="your_strong_jwt_secret_min_32_chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ── Frontend & CORS ───────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
# Comma-separated list of additional allowed origins (optional)
ALLOWED_ORIGINS=""

# ── Redis (cache + Bull queues) ───────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Notification Queues ───────────────────────────────────────────────────────
QUEUE_CONCURRENCY=5
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=5000

# ── WhatsApp via Evolution API ───────────────────────────────────────────────
# Self-hosted Evolution API instance — called by the Bull queue worker, not inline.
EVOLUTION_API_URL="https://your-evolution-host.example.com"
EVOLUTION_API_KEY="your-evolution-apikey"
EVOLUTION_INSTANCE="alshifa"
# Shown in the confirmation template; override per deployment if needed.
WHATSAPP_DEFAULT_CONSULTATION_MINUTES=30

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@alshifa.health

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@alshifa.health

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_MAX_MB=10
UPLOAD_DIR=uploads

# ── Auth (new) ────────────────────────────────────────────────────────────────
JWT_REFRESH_SECRET="your_strong_refresh_secret_min_32_chars"
MFA_ISSUER=Al-Shifa Healthcare

# ── Storage (Supabase) ──────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Infrastructure ───────────────────────────────────────────────────────────
REDIS_ADAPTER_ENABLED=false        # set true when running multiple instances
REDIS_CIRCUIT_BREAKER_THRESHOLD=5

# ── Monitoring ───────────────────────────────────────────────────────────────
LOG_LEVEL=info                     # debug | info | warn | error
LOG_DIR=./logs
ERROR_RATE_ALERT_THRESHOLD=10      # errors per minute before admin alert

# ── Sentry (optional) ───────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=

# ── CI/CD — set in GitHub Actions secrets, not here ─────────────────────────
# RENDER_DEPLOY_HOOK_URL=          # Production Render deploy hook
# RENDER_STAGING_DEPLOY_HOOK_URL=  # Staging Render deploy hook
