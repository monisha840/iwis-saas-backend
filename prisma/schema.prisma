// TongueObservation — shared between two capture paths:
//   • Self-exam (pre-existing): clinician-led Jihva Pariksha as part of a
//     multi-day SelfExamSubmission. Uses `coatingColor` + `coatingThickness`
//     enum columns and the (submissionId, dayIndex) uniqueness constraint.
//   • Daily check-in (F03): patient takes a tongue photo from the check-in
//     wizard; GPT-4o vision analyses against Jihva Pariksha criteria. Uses
//     `checkInId` + the `ai*` columns since the LLM's output vocabulary
//     (BROWN / GREY / MODERATE / DRY / WET / TRIDOSHA / BALANCED) is wider
//     than the existing enums and would cost a breaking enum extension.
//
// To accommodate both: submissionId / dayIndex / observedOn are nullable for
// the check-in path, the enum columns are nullable, and the new ai* columns
// are added side-by-side. The existing unique constraint is replaced with a
// partial expression that only enforces uniqueness when submissionId is set.
model TongueObservation {
  id                  String                  @id @default(uuid())
  // Self-exam path (legacy).
  submissionId        String?
  submission          SelfExamSubmission?     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  // Daily check-in path (F03). Optional — a clinician can still author a
  // self-exam observation without a check-in.
  checkInId           String?                 @unique
  checkIn             DailyCheckIn?           @relation(fields: [checkInId], references: [id], onDelete: SetNull)
  patientId           String
  patient             Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  dayIndex            Int?
  observedOn          DateTime?
  observedAt          DateTime                @default(now())
  photoUrl            String?
  // Legacy enum columns — populated only by the self-exam path.
  coatingColor        TongueCoatingColor?
  coatingThickness    TongueCoatingThickness?
  dryness             Boolean                 @default(false)
  cracks              Boolean                 @default(false)
  tremor              Boolean                 @default(false)
  correlatedPainLevel Int?
  notes               String?
  // F03 · AI analysis output (Jihva Pariksha via GPT-4o vision). All
  // nullable so a partial analysis (or fallback path) still produces a
  // valid record.
  aiCoatingColour     String?
  aiCoatingThickness  String?
  aiMoisture          String?
  doshaIndication     String?
  confidence          Float?
  analysisNotes       String?
  rawAnalysis         String?
  alertEmitted        Boolean                 @default(false)
  createdAt           DateTime                @default(now())

  @@index([patientId, observedAt])
  @@index([patientId, observedOn])
}

// Stool (Mala). Deliberately no image/photo field — texture is captured
