  previousScore          Float?
  previousUrgencyLevel   String?
  escalatedAfterUpdate   Boolean             @default(false)
  deEscalatedAfterUpdate Boolean             @default(false)
  // Auto-hold audit trail (what the server reserved on URGENT/CRITICAL)
