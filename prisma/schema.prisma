generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  password               String
  role                   Role
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  deletedAt              DateTime?
  bulkOperations         BulkOperation[]
  doctor                 Doctor?
  uploadedDocuments      Document[]
  sentMessages           Message[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  patient                Patient?
  pharmacist             Pharmacist?
  pharmacyDispenses      PharmacyDispense[]
  pharmacyOrders         PharmacyOrder[]
  therapist              Therapist?
  branch                 Branch?                 @relation(fields: [branchId], references: [id])
  branchId               String?
  auditLogs              AuditLog[]

  @@index([branchId])
}

model Branch {
  id                String              @id @default(uuid())
  name              String
  address           String?
  phone             String?
  email             String?
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  users             User[]
  patients          Patient[]
  appointments      Appointment[]
  prescriptions     Prescription[]
  pharmacyOrders    PharmacyOrder[]
  pharmacyDispenses PharmacyDispense[]
  medicineStocks    MedicineStock[]
  triageSessions    TriageSession[]
  invoices          Invoice[]
  payments          Payment[]
  videoPrescriptions VideoPrescription[]
  conversations     Conversation[]
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  oldData    Json?
  newData    Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model Doctor {
  id                 String              @id @default(uuid())
  userId             String              @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  clinic             String?
  fullName           String?
  profilePhoto       String?
  qualification      String?
  specialization     String?
  yearsExperience    Int?
  appointments       Appointment[]
  conversations      Conversation[]
  user               User                @relation(fields: [userId], references: [id])
  journeys           Journey[]
  prescriptions      Prescription[]
  videoPrescriptions VideoPrescription[]
  blockedSlots       BlockedSlot[]
}

model BlockedSlot {
  id          String     @id @default(uuid())
  doctorId    String?
  therapistId String?
  date        DateTime?
  dayOfWeek   Int?
  startTime   String
  endTime     String
  reason      String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  doctor      Doctor?    @relation(fields: [doctorId], references: [id])
  therapist   Therapist? @relation(fields: [therapistId], references: [id])

  @@index([doctorId])
  @@index([therapistId])
  @@index([date])
}

model Therapist {
  id                 String              @id @default(uuid())
  userId             String              @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  clinic             String?
  fullName           String?
  profilePhoto       String?
  qualification      String?
  specialization     String?
  yearsExperience    Int?
  appointments       Appointment[]
  availability       Availability[]
  conversations      Conversation[]
  journeys           Journey[]
  prescriptions      Prescription[]
  user               User                @relation(fields: [userId], references: [id])
  videoPrescriptions VideoPrescription[]
  blockedSlots       BlockedSlot[]
}

model Pharmacist {
  id              String   @id @default(uuid())
  userId          String   @unique
  fullName        String?
  profilePhoto    String?
  qualification   String?
  yearsExperience Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
  conversations   Conversation[]
}

model Patient {
  id                  String              @id @default(uuid())
  userId              String              @unique
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  age                 Int?
  dob                 DateTime?
  fullName            String?
  gender              String?
  patientId           String?             @unique
  phoneNumber         String?
  therapyType         String?
  onboardingCompleted Boolean             @default(false)
  onboardingData      Json?
  zenPoints           Int                 @default(0)
  appointments        Appointment[]
  conversations       Conversation[]
  dailyCheckIns       DailyCheckIn[]
  documents           Document[]
  invoices            Invoice[]
  journeys            Journey[]
  user                User                @relation(fields: [userId], references: [id])
  payments            Payment[]
  pharmacyDispenses   PharmacyDispense[]
  pharmacyOrders      PharmacyOrder[]
  prescriptions       Prescription[]
  triageSessions      TriageSession[]
  videoPrescriptions  VideoPrescription[]
  branch              Branch?             @relation(fields: [branchId], references: [id])
  branchId            String?
}

model DailyCheckIn {
  id         String   @id @default(uuid())
  patientId  String
  painLevel  Int
  mobilityScore Int?
  sleepHours    Float
  mood         String
  notes        String?
  createdAt    DateTime @default(now())
  patient    Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId, createdAt])
}

model ExerciseVideo {
  id            String              @id @default(uuid())
  title         String
  description   String?
  videoUrl      String
  thumbnail     String?
  category      String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  prescriptions VideoPrescription[]
}

model VideoPrescription {
  id          String        @id @default(uuid())
  patientId   String
  doctorId    String?
  therapistId String?
  videoId     String
  notes       String?
  createdAt   DateTime      @default(now())
  doctor      Doctor?       @relation(fields: [doctorId], references: [id])
  patient     Patient       @relation(fields: [patientId], references: [id])
  therapist   Therapist?    @relation(fields: [therapistId], references: [id])
  video       ExerciseVideo @relation(fields: [videoId], references: [id])
  branch      Branch?       @relation(fields: [branchId], references: [id])
  branchId    String?

  @@index([patientId])
}

model Appointment {
  id               String         @id @default(uuid())
  patientId        String
  doctorId         String?
  therapistId      String?
  date             DateTime
  status           String
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  consultationType ConsultationType @default(DOCTOR)
  consultationMode String         @default("OFFLINE")
  meetingLink      String?
  therapistDate    DateTime?
  sessionNotes     String?
  triageSessionId  String?        @unique
  doctor           Doctor?        @relation(fields: [doctorId], references: [id])
  patient          Patient        @relation(fields: [patientId], references: [id])
  therapist        Therapist?     @relation(fields: [therapistId], references: [id])
  triageSession    TriageSession? @relation(fields: [triageSessionId], references: [id])
  branch           Branch?        @relation(fields: [branchId], references: [id])
  branchId         String?
  doctorApproved   Boolean        @default(false)
  therapistApproved Boolean       @default(false)
  notificationSent  Boolean       @default(false)

  @@index([patientId])
  @@index([doctorId])
  @@index([therapistId])
  @@index([status])
  @@index([date])
  @@index([branchId])
}

model Prescription {
  id                String          @id @default(uuid())
  patientId         String
  doctorId          String?
  therapistId       String?
  medicineId        String?
  fileUrl           String?
  medicationName    String
  dosage            String
  frequency         String
  duration          String
  notes             String?
  totalQuantity     Int             @default(0)
  lowStockThreshold Int             @default(5)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  videoUrl          String?
  sku               String?
  doctor            Doctor?         @relation(fields: [doctorId], references: [id])
  medicine          Medicine?       @relation(fields: [medicineId], references: [id])
  patient           Patient         @relation(fields: [patientId], references: [id])
  therapist         Therapist?      @relation(fields: [therapistId], references: [id])
  medicationLogs    MedicationLog[]
  pharmacyDispenses PharmacyDispense[]
  pharmacyOrders    PharmacyOrder[]
  branch            Branch?            @relation(fields: [branchId], references: [id])
  branchId          String?

  @@index([patientId])
  @@index([doctorId])
  @@index([therapistId])
  @@index([createdAt])
  @@index([branchId])
}

model Availability {
  id          String    @id @default(uuid())
  therapistId String
  dayOfWeek   Int
  startTime   String
  endTime     String
  isApproved  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  therapist   Therapist @relation(fields: [therapistId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  priority  NotificationPriority @default(INFO)
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
}

enum NotificationPriority {
  HIGH
  MEDIUM
  LOW
  INFO
}

model NotificationPreference {
  id                   String  @id @default(uuid())
  userId               String  @unique
  emailEnabled         Boolean @default(true)
  smsEnabled           Boolean @default(false)
  pushEnabled          Boolean @default(true)
  appointmentReminders Boolean @default(true)
  systemAlerts         Boolean @default(true)
  prescriptionUpdates  Boolean @default(true)
  user                 User    @relation(fields: [userId], references: [id])
}

model Document {
  id              String         @id @default(uuid())
  patientId       String
  uploadedBy      String
  fileName        String
  fileUrl         String
  fileType        String
  fileSize        Int
  category        String
  description     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  triageSessionId String?
  patient         Patient        @relation(fields: [patientId], references: [id])
  triageSession   TriageSession? @relation(fields: [triageSessionId], references: [id])
  uploader        User           @relation(fields: [uploadedBy], references: [id])

  @@index([patientId])
  @@index([category])
  @@index([triageSessionId])
}

model Journey {
  id                String          @id @default(uuid())
  patientId         String
  doctorId          String
  therapistId       String?
  startDate         DateTime
  endDate           DateTime?
  status            String
  totalSessions     Int
  completedSessions Int             @default(0)
  progressNotes     String?
  treatmentGoals    String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  doctor            Doctor          @relation(fields: [doctorId], references: [id])
  patient           Patient         @relation(fields: [patientId], references: [id])
  therapist         Therapist?      @relation(fields: [therapistId], references: [id])
  medications       MedicationLog[]

  @@index([patientId, status])
  @@index([doctorId])
}

model MedicationLog {
  id             String        @id @default(uuid())
  journeyId      String?
  prescriptionId String?
  date           DateTime
  medicationName String
  dosage         String
  slot           String?
  scheduledTime  String?
  quantityTaken  Int           @default(1)
  taken          Boolean       @default(false)
  takenAt        DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  journey        Journey?      @relation(fields: [journeyId], references: [id])
  prescription   Prescription? @relation(fields: [prescriptionId], references: [id])

  @@index([journeyId, date])
  @@index([prescriptionId])
}

model BulkOperation {
  id               String    @id @default(uuid())
  type             String
  initiatedBy      String
  status           String
  totalRecords     Int
  processedRecords Int       @default(0)
  failedRecords    Int       @default(0)
  errorLog         Json?
  fileUrl          String?
  resultFileUrl    String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?
  user             User      @relation(fields: [initiatedBy], references: [id])

  @@index([initiatedBy])
  @@index([status])
}

model Payment {
  id            String   @id @default(uuid())
  patientId     String
  amount        Float
  currency      String   @default("INR")
  status        String
  paymentMethod String?
  transactionId String?  @unique
  description   String?
  appointmentId String?
  invoiceUrl    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  invoiceId     String?
  invoice       Invoice? @relation(fields: [invoiceId], references: [id])
  patient       Patient  @relation(fields: [patientId], references: [id])
  branch        Branch?  @relation(fields: [branchId], references: [id])
  branchId      String?

  @@index([patientId])
  @@index([status])
  @@index([createdAt])
  @@index([branchId])
}

model Medicine {
  id            String          @id @default(uuid())
  name          String
  brand         String?
  category      String?
  type          String?
  manufacturer  String?
  composition   String?
  description   String?
  price         Float
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  videoUrl      String?
  sku           String?         @unique
  dispenseItems DispenseItem[]
  invoiceItems       InvoiceItem[]
  stocks             MedicineStock[]
  prescriptions      Prescription[]
  pharmacyOrderItems PharmacyOrderItem[]

  @@index([name])
}

model MedicineStock {
  id          String   @id @default(uuid())
  medicineId  String
  batchNumber String
  expiryDate  DateTime
  quantity    Int
  minStock    Int      @default(10)
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  medicine    Medicine @relation(fields: [medicineId], references: [id])
  branch      Branch?  @relation(fields: [branchId], references: [id])
  branchId    String?

  @@index([medicineId])
  @@index([expiryDate])
  @@index([branchId])
}

model PharmacyDispense {
  id             String         @id @default(uuid())
  patientId      String
  prescriptionId String?
  dispensedBy    String
  totalAmount    Float
  status         String         @default("COMPLETED")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  items          DispenseItem[]
  dispenser      User           @relation(fields: [dispensedBy], references: [id])
  patient        Patient        @relation(fields: [patientId], references: [id])
  prescription   Prescription?  @relation(fields: [prescriptionId], references: [id])
  order          PharmacyOrder? @relation(fields: [orderId], references: [id])
  orderId        String?
  branch         Branch?        @relation(fields: [branchId], references: [id])
  branchId       String?

  @@index([patientId])
  @@index([createdAt])
  @@index([branchId])
}

model PharmacyOrder {
  id             String              @id @default(uuid())
  patientId      String
  prescriptionId String?
  orderedBy      String
  totalAmount    Float
  status         String              @default("PENDING") // PENDING, APPROVED, DISPATCHED, DELIVERED, CANCELLED
  urgency        String              @default("NORMAL") // NORMAL, URGENT, CRITICAL
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  items          PharmacyOrderItem[]
  dispenses      PharmacyDispense[]
  orderer        User                @relation(fields: [orderedBy], references: [id])
  patient        Patient             @relation(fields: [patientId], references: [id])
  prescription   Prescription?       @relation(fields: [prescriptionId], references: [id])
  branch         Branch?             @relation(fields: [branchId], references: [id])
  branchId       String?

  @@index([patientId])
  @@index([status])
  @@index([urgency])
  @@index([createdAt])
  @@index([branchId])
}

model PharmacyOrderItem {
  id         String        @id @default(uuid())
  orderId    String
  medicineId String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  order      PharmacyOrder @relation(fields: [orderId], references: [id])
  medicine   Medicine      @relation(fields: [medicineId], references: [id])
}

model DispenseItem {
  id         String           @id @default(uuid())
  dispenseId String
  medicineId String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  dispense   PharmacyDispense @relation(fields: [dispenseId], references: [id])
  medicine   Medicine         @relation(fields: [medicineId], references: [id])
}

model Invoice {
  id          String        @id @default(uuid())
  patientId   String
  totalAmount Float
  taxAmount   Float?        @default(0)
  discount    Float?        @default(0)
  netAmount   Float
  status      String        @default("UNPAID")
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  patient     Patient       @relation(fields: [patientId], references: [id])
  items       InvoiceItem[]
  payments    Payment[]
  branch      Branch?       @relation(fields: [branchId], references: [id])
  branchId    String?

  @@index([patientId])
  @@index([status])
  @@index([branchId])
}

model InvoiceItem {
  id          String    @id @default(uuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  medicineId  String?
  invoice     Invoice   @relation(fields: [invoiceId], references: [id])
  medicine    Medicine? @relation(fields: [medicineId], references: [id])
}

model TriageSession {
  id                 String       @id @default(uuid())
  patientId          String
  responses          Json
  severity           String
  suggestedSpecialty String?
  isEscalated        Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  appointment        Appointment?
  documents          Document[]
  patient            Patient      @relation(fields: [patientId], references: [id])
  branch             Branch?      @relation(fields: [branchId], references: [id])
  branchId           String?

  @@index([patientId])
  @@index([branchId])
}

model Conversation {
  id           String      @id @default(uuid())
  patientId    String
  doctorId     String?
  therapistId  String?
  pharmacistId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  doctor       Doctor?     @relation(fields: [doctorId], references: [id])
  patient      Patient     @relation(fields: [patientId], references: [id])
  therapist    Therapist?  @relation(fields: [therapistId], references: [id])
  pharmacist   Pharmacist? @relation(fields: [pharmacistId], references: [id])
  messages     Message[]
  branch       Branch?     @relation(fields: [branchId], references: [id])
  branchId     String?

  @@unique([patientId, doctorId])
  @@unique([patientId, therapistId])
  @@unique([patientId, pharmacistId])
  @@index([patientId])
  @@index([doctorId])
  @@index([therapistId])
  @@index([pharmacistId])
  @@index([branchId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
}

enum Role {
  ADMIN_DOCTOR
  DOCTOR
  THERAPIST
  PATIENT
  ADMIN
  PHARMACIST
}

enum ConsultationType {
  DOCTOR
  THERAPIST
  COMBINED
}

model LeaderboardConfig {
  id                    String   @id @default(uuid())
  appointmentWeight     Float    @default(0.2)
  adherenceWeight       Float    @default(0.2)
  responseTimeWeight    Float    @default(0.2)
  successRateWeight     Float    @default(0.2)
  consistencyWeight     Float    @default(0.2)
  targetAppointments    Int      @default(50)
  targetAdherence       Float    @default(90.0)
  targetSuccessRate     Float    @default(80.0)
  targetResponseTime    Float    @default(30.0) // minutes
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model LeaderboardAudit {
  id                String   @id @default(uuid())
  participantId     String
  participantRole   Role
  score             Float
  metrics           Json     // Stores the raw metrics used for calculation
  weights           Json     // Stores the weights used for calculation
  sourceRecordIds   Json?    // Tracks the IDs of original records used in scoring
  integrityHash     String?  // Hash of the data used for verification
  rank              Int?
  calculationDate   DateTime @default(now())
  
  @@index([participantId])
  @@index([calculationDate])
}
