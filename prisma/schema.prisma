// Reusable diet template with approval workflow.
// ADMIN / ADMIN_DOCTOR → auto APPROVED. DOCTOR → PENDING until admin approves.
// Only APPROVED packages can be assigned to patients (snapshots into
// DietPrescription + DietMeal rows at assignment time).
model DietPackage {
  id              String            @id @default(cuid())
  hospitalId      String?
  hospital        Hospital?         @relation(fields: [hospitalId], references: [id])
  title           String
  description     String?
  doshaTarget     DoshaType
  category        DietCategory
  durationDays    Int
  status          DietPackageStatus @default(PENDING)
  notes           String?
  isActive        Boolean           @default(true)
  createdById     String
  createdBy       User              @relation("DietPackageCreator", fields: [createdById], references: [id])
  approvedById    String?
  approvedBy      User?             @relation("DietPackageApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectionReason String?
