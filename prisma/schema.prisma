  originalUrgencyLevel   String?
  overriddenUrgencyLevel String?
  originalSpecialty      String?
  overriddenSpecialty    String?
  reason                 String?
  factorDisagreement     Json?
  createdAt              DateTime      @default(now())

  @@index([triageSessionId])
  @@index([reviewerUserId])
  @@index([createdAt])
}

