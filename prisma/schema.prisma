  bloatingGas           Boolean            @default(false)
  bloodPresent          Boolean            @default(false)
  mucusPresent          Boolean            @default(false)
  undigestedFood        Boolean            @default(false)
  relationshipToMeal    StoolMealRelation  @default(NONE)
