generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Migrations + introspection go through the DIRECT (session / unpooled)
  // URL so `prisma migrate` can hold a transaction across the whole run.
  // Runtime queries use the pooled DATABASE_URL. On Supabase this is:
  //   DATABASE_URL=pooler:6543?pgbouncer=true   (transaction mode)
  //   DIRECT_URL  =pooler:5432                  (session mode)
  directUrl = env("DIRECT_URL")
}

model User {
  id                         String                     @id @default(uuid())
  email                      String                     @unique
  password                   String
  role                       Role
  emailVerifiedAt            DateTime?
  tokensRevokedAt            DateTime?
  mfaEnabled                 Boolean                    @default(false)
  mfaSecret                  String?
  mfaBackupCodes             String[]
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  deletedAt                  DateTime?
  bulkOperations             BulkOperation[]
  doctor                     Doctor?
  uploadedDocuments          Document[]
  sentMessages               Message[]
  notifications              Notification[]
  notificationPreference     NotificationPreference?
  patient                    Patient?
  pharmacist                 Pharmacist?
  pharmacyDispenses          PharmacyDispense[]
  pharmacyOrders             PharmacyOrder[]
  therapist                  Therapist?
  branch                     Branch?                    @relation(fields: [branchId], references: [id])
  branchId                   String?
  hospital                   Hospital?                  @relation(fields: [hospitalId], references: [id])
  hospitalId                 String?
  auditLogs                  AuditLog[]
  refillRequests             RefillRequest[]
  refreshTokens              RefreshToken[]
  passwordResetTokens        PasswordResetToken[]
  // Journey relations
  treatmentJourneys          TreatmentJourney[]         @relation("JourneyPatient")
  doctorJourneys             TreatmentJourney[]         @relation("JourneyDoctor")
  // Group sessions this user authored (POST /api/group-sessions).
  groupSessionsCreated       GroupSession[]             @relation("GroupSessionCreator")
  taskCompletions            TaskCompletion[]
  patientVitals              PatientVital[]
  badges                     UserBadge[]
  createdCompetitions        BranchCompetition[]        @relation("CompetitionCreator")
  // New feature relations
  resourceSharings           ResourceSharing[]          @relation("SharedStaff")
  staffActivities            StaffActivity[]            @relation("StaffActivities")
  attendances                StaffAttendance[]          @relation("Attendances")
  skills                     StaffSkill[]               @relation("Skills")
  clinicianXP                ClinicianXP?               @relation("ClinicianXPProfile")
  xpTransactions             XPLedger[]                 @relation("XPTransactions")
  redemptions                RewardRedemption[]         @relation("Redemptions")
  mentorSessions             MentorSession[]            @relation("MentorSessions")
  menteeSessions             MentorSession[]            @relation("MenteeSessions")
  announcements              Announcement[]             @relation("Announcements")
  announcementReads          AnnouncementRead[]
  handoffsFrom               HandoffNote[]              @relation("HandoffFrom")
  handoffsTo                 HandoffNote[]              @relation("HandoffTo")
  // SUPER_ADMIN relations
  enabledFeatureFlags        HospitalFeatureFlag[]      @relation("FeatureFlagEnabledBy")
  superAdminAuditLogs        SuperAdminAuditLog[]       @relation("SuperAdminActor")
  // Triage v2
  triageOverridesReviewed    TriageOverride[]           @relation("TriageOverrideReviewer")
  // Dashboard refactor — todos
  todosCreated               Todo[]                     @relation("TodoCreatedBy")
  todosAssigned              Todo[]                     @relation("TodoAssignedTo")
  // Vitals this clinician has prescribed for patients
  prescribedVitals           PrescribedVital[]          @relation("PrescribedVitalAuthor")
  // Self-examination protocol — clinician reviewer
  selfExamReviews            SelfExamSubmission[]       @relation("SelfExamReviewer")
  // Admin-tunable per-zone test protocol overrides
  selfExamProtocolEdits      SelfExamProtocolOverride[] @relation("SelfExamProtocolEditor")
  // Diet package authoring & approval
  dietPackagesCreated        DietPackage[]              @relation("DietPackageCreator")
  dietPackagesApproved       DietPackage[]              @relation("DietPackageApprover")
  // Patient assignments this admin / admin-doctor has made
  patientAssignmentsMade     PatientAssignment[]        @relation("PatientAssignedBy")
  // Messaging template authorship
  messageTemplatesCreated    MessageTemplate[]          @relation("TemplateCreator")
  messageTemplatesEdited     MessageTemplate[]          @relation("TemplateEditor")
  // Appointment reminder authorship (per-appointment override)
  appointmentRemindersEdited Appointment[]              @relation("AppointmentReminderEditor")
  // Reminder deliveries targeted at this user (patient)
  reminderDeliveriesReceived ReminderDeliveryLog[]      @relation("ReminderTarget")
  // Follow-up schedules this clinician has assigned after a completed consultation
  followUpsCreated           AppointmentFollowUp[]      @relation("FollowUpCreator")
  // Critical-journey flags this clinician has marked as resolved
  criticalFlagsResolved      PatientCriticalFlag[]      @relation("CriticalFlagResolver")
  // Staff messaging (DMs + group chats)
  staffThreadsCreated        StaffThread[]              @relation("StaffThreadCreator")
  staffThreadMemberships     StaffThreadMember[]        @relation("StaffThreadMembership")
  staffThreadMembersAdded    StaffThreadMember[]        @relation("StaffMemberAddedBy")
  staffMessagesSent          StaffMessage[]             @relation("StaffMessageSender")
  // Journey feedback (patient-side submissions + lead-doctor attribution)
  journeyFeedbackPatient     JourneyFeedback[]          @relation("JourneyFeedbackPatient")
  journeyFeedbackLeadDoctor  JourneyFeedback[]          @relation("JourneyFeedbackLeadDoctor")
  journeyFeedbackPrimary     JourneyFeedback[]          @relation("JourneyFeedbackPrimaryClinician")
  thankYouCardsReceived      ThankYouCard[]             @relation("ThankYouCardRecipient")
  // Flattened export-friendly snapshot kept in sync with this user
  snapshot                   UserSnapshot?
  // Ayurvedic Food Database + Recipe Library (Feature 1) — authorship trails
  createdFoods               AyurvedicFood[]            @relation("UserCreatedFoods")
  createdRecipes             AyurvedicRecipe[]          @relation("UserCreatedRecipes")

  @@index([branchId])
  @@index([hospitalId])
}

/// Flattened, role-agnostic record of every user's reportable core data.
/// Maintained in lock-step with User via UserService.upsertSnapshot() so
/// the admin export endpoint can serve a single denormalised query without
/// having to join across Doctor / Therapist / Patient / Pharmacist tables.
model UserSnapshot {
  userId      String   @id
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String?
  email       String
  role        String
  branchId    String?
  branchName  String?
  hospitalId  String?
  phoneNumber String?
  status      String // ACTIVE | DELETED | INVITED
  createdAt   DateTime
  updatedAt   DateTime @default(now())

  @@index([role])
  @@index([branchId])
  @@index([hospitalId])
  @@index([status])
}

model RefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  deviceInfo String?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Branch {
  id                   String                   @id @default(uuid())
  name                 String
  address              String?
  phone                String?
  email                String?
  isActive             Boolean                  @default(true)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  hospitalId           String
  hospital             Hospital                 @relation(fields: [hospitalId], references: [id])
  // Capacity & operations (IWIS competitor feature 0)
  totalBeds            Int?
  availableBeds        Int?
  totalRooms           Int?
  totalTherapyRooms    Int?
  ipdEnabled           Boolean                  @default(false)
  opdEnabled           Boolean                  @default(true)
  operatingHoursFrom   String?
  operatingHoursTo     String?
  // Weekday ordinals (0=Sun, 6=Sat) when the clinic is closed. Empty = open
  // every day. Honoured by the attendance reconciliation so closed-day
  // shifts don't produce false ABSENT rows. Default empty so existing
  // clinics retain their previous "open every day" behaviour until an
  // admin explicitly marks weekends off.
  weeklyClosedDays     Int[]                    @default([])
  users                User[]
  patients             Patient[]
  appointments         Appointment[]
  prescriptions        Prescription[]
  pharmacyOrders       PharmacyOrder[]
  pharmacyDispenses    PharmacyDispense[]
  medicineStocks       MedicineStock[]
  triageSessions       TriageSession[]
  invoices             Invoice[]
  payments             Payment[]
  videoPrescriptions   VideoPrescription[]
  conversations        Conversation[]
  treatmentJourneys    TreatmentJourney[]
  competitionEntries   BranchCompetitionEntry[]
  // New feature relations
  sharingFrom          ResourceSharing[]        @relation("SharingFrom")
  sharingTo            ResourceSharing[]        @relation("SharingTo")
  transfersFrom        StockTransfer[]          @relation("TransferFrom")
  transfersTo          StockTransfer[]          @relation("TransferTo")
  staffActivities      StaffActivity[]          @relation("StaffBranchActivity")
  branchAttendance     StaffAttendance[]        @relation("BranchAttendance")
  announcements        Announcement[]           @relation("AnnouncementTargetBranches")
  handoffNotes         HandoffNote[]            @relation("HandoffToBranch")
  // IWIS competitor features
  therapyRooms         TherapyRoom[]
  treatmentPackages    TreatmentPackage[]
  groupSessions        GroupSession[]
  // Dashboard refactor — todos scoped to this branch
  todos                Todo[]                   @relation("TodoBranch")
  // Self-examination protocol submissions (branch-scoped for admin review)
  selfExamSubmissions  SelfExamSubmission[]
  // Critical-journey flags scoped to this branch (for branch-filtered admin dashboards)
  criticalFlags        PatientCriticalFlag[]
  // Staff group chats scoped to this branch
  staffThreads         StaffThread[]
  consultationFeedback ConsultationFeedback[]
  // Journey feedback scoped to this branch (for branch-filtered admin views)
  journeyFeedback      JourneyFeedback[]        @relation("JourneyFeedbackBranch")
  queueEntries         QueueEntry[]
  homeTherapyRequests  HomeTherapyRequest[]
  // Ayurvedic Food Database + Recipe Library (Feature 1)
  ayurvedicFoods       AyurvedicFood[]          @relation("BranchAyurvedicFoods")
  recipes              AyurvedicRecipe[]        @relation("BranchRecipes")
  // Branded PDF health reports + WhatsApp delivery (Feature 2)
  healthReports        HealthReport[]
  // No-code workflow automation rules (Feature 3)
  workflowRules        WorkflowRule[]
}

// Live patient queue / arrival tracking. One row per appointment per day
// the patient is expected. Created lazily by queueService when the queue
// is first read or when state transitions are triggered. Powers the
// doctor's Today's Queue panel and the admin/branch-admin Live Queue
// Board. Mirrors the queue-related fields on Appointment — both are
// written in the same transaction so they cannot drift.
model QueueEntry {
  id                    String    @id @default(uuid())
  appointmentId         String    @unique
  doctorId              String
  branchId              String
  // Date-only column so a doctor's queue lookup for "today" is a clean
  // equality match irrespective of the appointment's clock time.
  date                  DateTime  @db.Date
  queuePosition         Int
  arrivalStatus         String    @default("NOT_ARRIVED")
  arrivedAt             DateTime?
  consultationStartedAt DateTime?
  consultationEndedAt   DateTime?
  absentContactedAt     DateTime?
  contactNote           String?
  // Who marked the patient as contacted (admin / branch_admin / admin_doctor)
  contactedById         String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor      Doctor      @relation(fields: [doctorId], references: [id])
  branch      Branch      @relation(fields: [branchId], references: [id])

  @@index([doctorId, date, branchId])
  @@index([branchId, date])
  @@index([date, arrivalStatus])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  oldData    Json?
  newData    Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@index([userId, createdAt]) // User activity audit trail sorted by date
  @@index([action, createdAt]) // Action-type queries sorted by date
}

model Doctor {
  id                   String                 @id @default(uuid())
  userId               String                 @unique
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  clinic               String?
  fullName             String?
  profilePhoto         String?
  qualification        String?
  specialization       String?
  yearsExperience      Int?
  // Certificate / medical registration number (e.g. CCIM, state AYUSH
  // board). Nullable on the schema for back-compat; required at the form
  // and route layer for new records.
  registrationNumber   String?
  // Self-editable personal details surfaced on ProfilePage.
  phoneNumber          String?
  bio                  String?
  languages            String[]               @default([])
  appointments         Appointment[]
  conversations        Conversation[]
  user                 User                   @relation(fields: [userId], references: [id])
  journeys             Journey[]
  prescriptions        Prescription[]
  videoPrescriptions   VideoPrescription[]
  blockedSlots         BlockedSlot[]
  // IWIS competitor features
  dietPrescriptions    DietPrescription[]
  patientAssignments   PatientAssignment[]
  consultationFeedback ConsultationFeedback[]
  queueEntries         QueueEntry[]
  homeTherapyRequests  HomeTherapyRequest[]
  // Branded PDF health reports + WhatsApp delivery (Feature 2)
  healthReports        HealthReport[]
  // Auto-generated follow-up tasks (Feature 5)
  followUpTasks        FollowUpTask[]
}

// Canonical record of who's looking after a patient. Supersedes the old
// "create a fake Appointment with status=ASSIGNED" hack.
//
//  - PRIMARY: the patient's main clinician. At most one ACTIVE PRIMARY at a
//    time; assigning a new PRIMARY automatically flips any previous ACTIVE
//    PRIMARY to REPLACED (preserving history).
//  - CONSULTING: secondary / specialist opinion. Multiple allowed.
//  - TEMPORARY: short-term cross-branch cover. Multiple allowed.
//
// Rows are never deleted — status transitions preserve the audit trail.
model PatientAssignment {
  id           String           @id @default(cuid())
  patientId    String
  patient      Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId     String
  doctor       Doctor           @relation(fields: [doctorId], references: [id])
  type         AssignmentType   @default(PRIMARY)
  status       AssignmentStatus @default(ACTIVE)
  reason       String?
  assignedById String
  assignedBy   User             @relation("PatientAssignedBy", fields: [assignedById], references: [id])
  assignedAt   DateTime         @default(now())
  endedAt      DateTime?
  endReason    String?

  @@index([patientId, status])
  @@index([doctorId, status])
  @@index([assignedById])
}

enum AssignmentType {
  PRIMARY
  CONSULTING
  TEMPORARY
}

enum AssignmentStatus {
  ACTIVE
  ENDED
  REPLACED
}

model BlockedSlot {
  id          String     @id @default(uuid())
  doctorId    String?
  therapistId String?
  date        DateTime?
  dayOfWeek   Int?
  startTime   String
  endTime     String
  reason      String?
  // Classifies the block so the nightly attendance reconciliation can map
  // a full-day block to the correct AttendanceStatus (LEAVE / WFH / OFF).
  // Anything else falls through as OTHER and is treated as generic
  // unavailability (does not flip attendance automatically).
  kind        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  doctor      Doctor?    @relation(fields: [doctorId], references: [id])
  therapist   Therapist? @relation(fields: [therapistId], references: [id])

  @@index([doctorId])
  @@index([therapistId])
  @@index([date])
  @@index([kind])
  // Composite indexes for the availability check queries
  @@index([doctorId, date, dayOfWeek]) // checkAvailability + getAvailableSlots
  @@index([therapistId, date, dayOfWeek]) // checkAvailability + getAvailableSlots
}

model Therapist {
  id                  String               @id @default(uuid())
  userId              String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  clinic              String?
  fullName            String?
  profilePhoto        String?
  qualification       String?
  // Therapists are categorized by gender (MALE / FEMALE) only — no
  // specialization field. Skill mix lives separately on TherapistSkill.
  gender              String?
  yearsExperience     Int?
  // Certificate / registration number (e.g. AYUSH / state therapy board).
  // Nullable on the schema for back-compat; required at the form and route
  // layer for new records.
  registrationNumber  String?
  // Self-editable personal details surfaced on ProfilePage.
  phoneNumber         String?
  bio                 String?
  languages           String[]             @default([])
  appointments        Appointment[]
  availability        Availability[]
  conversations       Conversation[]
  journeys            Journey[]
  prescriptions       Prescription[]
  user                User                 @relation(fields: [userId], references: [id])
  videoPrescriptions  VideoPrescription[]
  blockedSlots        BlockedSlot[]
  // IWIS competitor features
  therapistSkills     TherapistSkill[]
  groupSessions       GroupSession[]
  packageSessionLogs  PackageSessionLog[]  @relation("PackageSessionConductor")
  homeTherapySessions HomeTherapySession[]
  // SOAP-format session notes authored by this therapist. See model
  // TherapistSessionNote below.
  sessionNotes        TherapistSessionNote[]
  // Structured per-session outcome rows (pain / mobility / swelling /
  // observations) authored by this therapist. See model TherapyOutcome.
  therapyOutcomes     TherapyOutcome[]
}

model Pharmacist {
  id              String         @id @default(uuid())
  userId          String         @unique
  fullName        String?
  profilePhoto    String?
  qualification   String?
  yearsExperience Int?
  // Self-editable personal details surfaced on ProfilePage.
  phoneNumber     String?
  bio             String?
  languages       String[]       @default([])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id])
  conversations   Conversation[]
}

model Patient {
  id                   String                       @id @default(uuid())
  userId               String                       @unique
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  age                  Int?
  dob                  DateTime?
  fullName             String?
  gender               String?
  profilePhoto         String?
  patientId            String?                      @unique
  phoneNumber          String?
  therapyType          String?
  onboardingCompleted  Boolean                      @default(false)
  onboardingData       Json?
  zenPoints            Int                          @default(0)
  appointments         Appointment[]
  conversations        Conversation[]
  dailyCheckIns        DailyCheckIn[]
  // Behavioural Nudge Engine (F05) — one row per outbound nudge with the
  // resulting check-in completion stamped retroactively when the patient
  // submits within the message window.
  nudgeLogs            NudgeLog[]
  // Predictive Dosha Engine (F04) — one row per nightly forecast run that
  // crosses the alert threshold. History so clinicians can see whether
  // predictions were borne out.
  doshaForecasts       DoshaForecast[]
  documents            Document[]
  invoices             Invoice[]
  journeys             Journey[]
  user                 User                         @relation(fields: [userId], references: [id])
  payments             Payment[]
  pharmacyDispenses    PharmacyDispense[]
  pharmacyOrders       PharmacyOrder[]
  prescriptions        Prescription[]
  triageSessions       TriageSession[]
  videoPrescriptions   VideoPrescription[]
  branch               Branch?                      @relation(fields: [branchId], references: [id])
  branchId             String?
  refillRequests       RefillRequest[]
  referralsMade        Referral[]                   @relation("PatientReferrals")
  referralsReceived    Referral[]                   @relation("PatientReferredBy")
  retentionChecklists  RetentionChecklist[]
  appointmentFeedback  AppointmentFeedback[]
  consultationFeedback ConsultationFeedback[]
  challengeCompletions PatientChallengeCompletion[]
  zenPointsLedger      ZenPointsLedger[]
  patientStreak        PatientStreak?
  // New feature relations
  questProgress        PatientQuestProgress[]
  healthAvatar         HealthAvatar?
  familiesCreated      PatientFamily[]              @relation("FamilyCreator")
  familyMemberships    PatientFamilyMember[]
  contentUnlocks       ContentUnlock[]
  handoffNotes         HandoffNote[]
  visitSummaries       VisitSummary[]
  // IWIS competitor features
  dietPrescriptions    DietPrescription[]
  dietAdherenceLogs    DietAdherenceLog[]
  clinicalPhotos       ClinicalPhoto[]
  packageEnrolments    PackageEnrolment[]
  // Dashboard refactor — todos linked to this patient for context
  todos                Todo[]                       @relation("TodoRelatedPatient")
  // Vitals the doctor has prescribed this patient to track
  prescribedVitals     PrescribedVital[]
  // Self-examination protocol (IWIS pre-consultation workflow)
  selfExamSubmissions  SelfExamSubmission[]
  tongueObservations   TongueObservation[]
  stoolLogs            StoolLog[]
  urineLogs            UrineLog[]
  constitutionProfile  ConstitutionProfile?
  // Primary-care doctor history (canonical source of who's looking after
  // this patient). Join table supports history, reassignment audit, and
  // future primary-vs-consulting doctor splits.
  patientAssignments   PatientAssignment[]
  // Follow-up schedules assigned at consultation completion
  followUps            AppointmentFollowUp[]
  // Critical-journey flag (at most one active row per patient — upsert-based)
  criticalFlag         PatientCriticalFlag?
  // Ayurvedic Voice Health Coach (AYURVEDIC_VOICE_COACH feature flag).
  // Per-patient enable + preferred response language ('ta' | 'en').
  voiceCoachEnabled    Boolean                      @default(true)
  preferredCoachLang   String                       @default("ta")
  voiceConversations   VoiceConversation[]

  // ── Home Therapy: location & contact fields ──────────────────────────────
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  pincode          String?
  latitude         Float?
  longitude        Float?
  primaryPhone     String?
  alternativePhone String?
  locationVerified Boolean @default(false)

  homeTherapyRequests HomeTherapyRequest[]
  homeTherapySessions HomeTherapySession[]
  // SOAP session notes authored about this patient by their therapist(s).
  therapistSessionNotes TherapistSessionNote[]
  // Per-session therapy outcome scores (pain / mobility / swelling)
  // authored by therapists working on this patient. See TherapyOutcome.
  therapyOutcomes       TherapyOutcome[]
  // Structured allergy list — used by AyurvedicFood conflict-check
  // (Feature 1). Empty array by default; populated from onboarding form
  // or by a clinician during intake.
  allergies           String[]             @default([])
  // Branded PDF health reports + WhatsApp delivery (Feature 2)
  healthReports       HealthReport[]
  // Auto-generated follow-up tasks (Feature 5)
  followUpTasks       FollowUpTask[]
  // Workflow automation engine logs + cooldowns (Feature 3)
  workflowRuleLogs    WorkflowRuleLog[]
  workflowCooldowns   WorkflowCooldown[]
  // Sheizen-inspired daily tracking — water, activity, body measurements,
  // meal photos. Patient-only logging surfaces under /api/daily-tracking/*.
  waterIntakeLogs     WaterIntakeLog[]
  activityLogs        ActivityLog[]
  bodyMeasurementLogs BodyMeasurementLog[]
  mealPhotoLogs       MealPhotoLog[]
  // Monday Motivation card — one per patient per day. Cron-generated every
  // Monday and lazy-created on dashboard load for mid-week onboardings.
  motivationCards     DailyMotivationCard[]

  @@index([branchId]) // branch-scoped patient queries (listPatients, triage dispatch)
}

model DailyCheckIn {
  id                String              @id @default(uuid())
  patientId         String
  // F03 — optional Jihva Pariksha attachment from the check-in wizard's
  // Step 3. Nullable: most check-ins won't have one. 1:1 because the wizard
  // only allows one photo per check-in.
  tongueObservation TongueObservation?
  painLevel         Int
  // Structured per-region pain log captured via the body-map step of the
  // 3-step daily check-in. Shape (JSON array): [{ regionId, regionLabel,
  // intensity (1-10), characters: string[], radiates: bool, radiatesTo? }].
  // Mirrors TriageSession.painRegions so the same body-map component renders
  // both. painLevel is kept as the legacy/derived max intensity for older
  // analytics paths and quick filtering.
  painRegions   Json?
  mobilityScore Int?
  sleepHours    Float
  mood          String
  notes         String?
  createdAt     DateTime @default(now())
  patient       Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId, createdAt])
}

model ExerciseVideo {
  id            String              @id @default(uuid())
  title         String
  description   String?
  videoUrl      String
  thumbnail     String?
  category      String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  prescriptions VideoPrescription[]
}

model VideoPrescription {
  id          String        @id @default(uuid())
  patientId   String
  doctorId    String?
  therapistId String?
  videoId     String
  notes       String?
  createdAt   DateTime      @default(now())
  doctor      Doctor?       @relation(fields: [doctorId], references: [id])
  patient     Patient       @relation(fields: [patientId], references: [id])
  therapist   Therapist?    @relation(fields: [therapistId], references: [id])
  video       ExerciseVideo @relation(fields: [videoId], references: [id])
  branch      Branch?       @relation(fields: [branchId], references: [id])
  branchId    String?

  @@index([patientId])
}

model Appointment {
  id                        String                @id @default(uuid())
  patientId                 String
  doctorId                  String?
  therapistId               String?
  date                      DateTime
  status                    String
  notes                     String?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  consultationType          ConsultationType      @default(DOCTOR)
  consultationMode          String                @default("OFFLINE")
  meetingLink               String?
  therapistDate             DateTime?
  sessionNotes              String?
  triageSessionId           String?               @unique
  dailyRoomName             String?
  dailyRoomUrl              String?
  dailyRoomExpiry           DateTime?
  videoSessionStartedAt     DateTime?
  videoSessionEndedAt       DateTime?
  doctor                    Doctor?               @relation(fields: [doctorId], references: [id])
  patient                   Patient               @relation(fields: [patientId], references: [id])
  therapist                 Therapist?            @relation(fields: [therapistId], references: [id])
  triageSession             TriageSession?        @relation(fields: [triageSessionId], references: [id])
  branch                    Branch?               @relation(fields: [branchId], references: [id])
  branchId                  String?
  doctorApproved            Boolean               @default(false)
  therapistApproved         Boolean               @default(false)
  notificationSent          Boolean               @default(false)
  // Walk-in marker. Set true by POST /api/appointments/walk-in so the
  // frontend's AppointmentCard / appointment-list can render a "Walk-In"
  // badge. Standard patient-initiated bookings leave it at the default.
  isWalkIn                  Boolean               @default(false)
  // Optional free-text notes captured on the walk-in form (separate from
  // the canonical `notes` column so the admin's reason / context can be
  // shown alongside the auto-generated "Walk-in booking" header).
  walkInNotes               String?
  csatSentAt                DateTime?
  retentionChecklist        RetentionChecklist?
  feedback                  AppointmentFeedback?
  consultationFeedback      ConsultationFeedback?
  visitSummary              VisitSummary?
  // IWIS competitor features
  therapyRoomId             String?
  therapyRoomBooking        TherapyRoomBooking?
  groupSessionId            String?
  groupSession              GroupSession?         @relation(fields: [groupSessionId], references: [id])
  isGroupBooking            Boolean               @default(false)
  packageSessionLogs        PackageSessionLog[]
  prescriptions             Prescription[]
  // Dashboard refactor — todos linked to this appointment
  todos                     Todo[]                @relation("TodoRelatedAppointment")
  // Self-examination protocol submission prepared for this Vaidya visit
  selfExamSubmissions       SelfExamSubmission[]
  // Auto-seeded handoff draft created when this appointment is marked COMPLETED
  handoffNoteDraft          HandoffNote?          @relation("AppointmentHandoffDraft")
  // Per-appointment custom reminder message — set at booking time by admin/doctor
  customReminderTemplateId  String?
  customReminderTemplate    MessageTemplate?      @relation("AppointmentCustomTemplate", fields: [customReminderTemplateId], references: [id], onDelete: SetNull)
  customReminderBody        String?
  customReminderSubject     String?
  customReminderChannels    DeliveryChannel[]     @default([])
  customReminderUpdatedAt   DateTime?
  customReminderUpdatedById String?
  customReminderUpdatedBy   User?                 @relation("AppointmentReminderEditor", fields: [customReminderUpdatedById], references: [id], onDelete: SetNull)
  reminderDeliveryLogs      ReminderDeliveryLog[]
  // Follow-up schedule captured at consultation completion (1:1)
  followUp                  AppointmentFollowUp?
  // Optional link to a TreatmentJourney — drives co-treater XP attribution
  // on JourneyFeedback. Existing rows stay null; populated by booking flow
  // or admin tooling going forward.
  journeyId                 String?
  journey                   TreatmentJourney?     @relation("JourneyAppointments", fields: [journeyId], references: [id], onDelete: SetNull)

  // ── Live queue / arrival tracking (IWIS Patient Queue Mgmt) ─────────────
  // Mirrors fields on QueueEntry so non-queue queries (timeline, doctor
  // calendar) can filter by arrival without a join. Single source of truth
  // is QueueEntry — both rows are written in the same transaction by
  // queueService.* so they cannot drift.
  // Status values (string, matches existing Appointment.status convention):
  //   NOT_ARRIVED, ARRIVED, IN_CONSULTATION, COMPLETED, ABSENT, CONTACTED
  arrivalStatus         String              @default("NOT_ARRIVED")
  arrivedAt             DateTime?
  consultationStartedAt DateTime?
  consultationEndedAt   DateTime?
  queuePosition         Int?
  absentContactedAt     DateTime?
  queueEntry            QueueEntry?
  // Optional 1:1 link to a HomeTherapySession (when this Appointment was
  // auto-created by the home-therapy approval flow).
  homeTherapySession    HomeTherapySession?
  // SOAP notes written by the therapist after the sitting — one Appointment
  // can carry multiple notes when a single visit covers more than one
  // therapy modality.
  therapistSessionNotes TherapistSessionNote[]
  // Structured per-session outcome rows (pain/mobility scores) tied to
  // the appointment they were recorded on. Optional — outcomes can also
  // exist without a linked appointment.
  therapyOutcomes       TherapyOutcome[]
  // Branded PDF health reports + WhatsApp delivery (Feature 2)
  healthReports         HealthReport[]

  @@index([patientId])
  @@index([doctorId])
  @@index([therapistId])
  @@index([status])
  @@index([date])
  @@index([branchId])
  @@index([journeyId])
  // Composite indexes for high-frequency joined queries
  @@index([doctorId, date]) // Availability check: "is the doctor free on date X?"
  @@index([therapistId, date]) // Availability check: "is the therapist free on date X?"
  @@index([patientId, status]) // Patient dashboard: filter by status
  @@index([status, date]) // Admin dashboard: date-range + status filter
  @@index([branchId, date]) // Branch reporting: appointments per branch per period
  @@index([notificationSent, status]) // Webhook retry: find confirmed, un-notified appointments
  @@index([patientId, status, date]) // Patient appointment history filtered by status + date
  @@index([doctorId, date, status]) // Doctor schedule: date range filtered by status
}

model Prescription {
  id                   String               @id @default(uuid())
  patientId            String
  doctorId             String?
  therapistId          String?
  medicineId           String?
  fileUrl              String?
  medicationName       String
  dosage               String
  frequency            String
  duration             String
  notes                String?
  // Legacy counter — retained for back-compat. dispensedQty / consumedQty are
  // the new source of truth for supply tracking (see medicationLifecycle.service.js).
  totalQuantity        Int                  @default(0)
  lowStockThreshold    Int                  @default(5)
  refillNotifiedAt     DateTime?
  // ── Lifecycle tracking ─────────────────────────────────────────────────
  startDate            DateTime?
  expectedEndDate      DateTime?
  dailyDoseCount       Int?
  dispensedQty         Int                  @default(0)
  consumedQty          Int                  @default(0)
  missedDoseNotifiedAt DateTime?
  missedDoseStreak     Int                  @default(0)
  threeDayNotifiedAt   DateTime?
  lastDayNotifiedAt    DateTime?
  discontinuedAt       DateTime?
  discontinuedReason   String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  videoUrl             String?
  sku                  String?
  doctor               Doctor?              @relation(fields: [doctorId], references: [id])
  medicine             Medicine?            @relation(fields: [medicineId], references: [id])
  patient              Patient              @relation(fields: [patientId], references: [id])
  therapist            Therapist?           @relation(fields: [therapistId], references: [id])
  medicationLogs       MedicationLog[]
  pharmacyDispenses    PharmacyDispense[]
  pharmacyOrders       PharmacyOrder[]
  branch               Branch?              @relation(fields: [branchId], references: [id])
  branchId             String?
  refillRequests       RefillRequest[]
  // Optional: prescription written during a specific appointment. Used by
  // VisitSummary to surface the exact prescriptions authored during the visit.
  appointmentId        String?
  appointment          Appointment?         @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  // Optional link to a TreatmentPackage selected during prescription
  // creation. Lets the receiving pharmacist / patient see the broader
  // package context without joining through PackageEnrolment.
  packageId            String?
  package              TreatmentPackage?    @relation(fields: [packageId], references: [id], onDelete: SetNull)
  // Optional link to a TreatmentJourney created in the same atomic save.
  // Populated by the prescription+journey transaction in prescription.service.js.
  journeyId            String?
  journey              TreatmentJourney?    @relation("JourneyPrescriptions", fields: [journeyId], references: [id], onDelete: SetNull)
  // Home Therapy referrals authored alongside this prescription
  homeTherapyRequests  HomeTherapyRequest[]

  @@index([patientId])
  @@index([doctorId])
  @@index([therapistId])
  @@index([createdAt])
  @@index([branchId])
  @@index([appointmentId])
  @@index([packageId])
  @@index([journeyId])
  @@index([discontinuedAt, expectedEndDate])
}

model Availability {
  id          String    @id @default(uuid())
  therapistId String
  dayOfWeek   Int
  startTime   String
  endTime     String
  isApproved  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  therapist   Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId]) // Basic FK index (was missing)
  @@index([therapistId, dayOfWeek]) // Slot lookup: schedule for a clinician on a given day
  @@index([therapistId, isApproved]) // Approved availability filter
}

model Notification {
  id         String                 @id @default(uuid())
  userId     String
  type       String
  title      String
  message    String
  priority   NotificationPriority   @default(INFO)
  isRead     Boolean                @default(false)
  data       Json?
  /// Optional: ID of the related entity (appointment, prescription, etc.)
  /// Used for idempotency checks — prevents duplicate in-app notifications.
  relatedId  String?
  createdAt  DateTime               @default(now())
  user       User                   @relation(fields: [userId], references: [id])
  deliveries NotificationDelivery[]

  @@index([userId, isRead])
  @@index([createdAt])
  @@index([relatedId, type]) // Idempotency: check if notification already sent for a given entity+type
  @@index([userId, type, createdAt]) // Deduplication queries: "has this user been sent type X recently?"
  @@index([userId, isRead, createdAt]) // Unread notifications feed sorted by date
}

model NotificationDelivery {
  id             String       @id @default(uuid())
  notificationId String
  channel        String // PUSH, WEBHOOK, IN_APP, WHATSAPP
  status         String       @default("PENDING") // PENDING, SENT, FAILED, BOUNCED
  externalId     String? // provider message id (Evolution, web-push receipt, etc.)
  errorMessage   String?
  attemptCount   Int          @default(0)
  sentAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([status, createdAt])
  @@index([channel, status])
}

enum NotificationPriority {
  HIGH
  MEDIUM
  LOW
  INFO
}

