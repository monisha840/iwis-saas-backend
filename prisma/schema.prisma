enum HandoffStatus {
  DRAFT
  SENT
  ARCHIVED
}

model HandoffNote {
  id                 String    @id @default(cuid())
  patientId          String
  patient            Patient   @relation(fields: [patientId], references: [id])
  fromClinicianId    String
  fromClinician      User      @relation("HandoffFrom", fields: [fromClinicianId], references: [id])
  toClinicianId      String?
  toClinician        User?     @relation("HandoffTo", fields: [toClinicianId], references: [id])
  toBranchId         String?
  toBranch           Branch?   @relation("HandoffToBranch", fields: [toBranchId], references: [id])
  summary            String
  currentMedications Json? // [{ name, dosage, frequency }]
  activeConditions   String[]
  nextSteps          String?
  urgency            String    @default("NORMAL") // LOW, NORMAL, HIGH, CRITICAL
  isRead             Boolean   @default(false)
  readAt             DateTime?
  createdAt          DateTime  @default(now())

  status              HandoffStatus @default(SENT)
  isAutoGenerated     Boolean       @default(false)
  sourceAppointmentId String?       @unique
  sourceAppointment   Appointment?  @relation("AppointmentHandoffDraft", fields: [sourceAppointmentId], references: [id], onDelete: SetNull)
  sentAt              DateTime?
  // User-supplied effective date for the handoff (DD/MM/YYYY in the
  // create form; converted to a DateTime by the service). The
  // receiving doctor's notification surfaces this so they know when
  // the handoff goes "live".
  handoffDate         DateTime?

  @@index([patientId])
  @@index([fromClinicianId])
  @@index([toClinicianId])
  @@index([toBranchId])
  @@index([isRead])
  @@index([status])
  @@index([fromClinicianId, status])
}

// SOAP-format session notes authored by a therapist after a sitting.
// Distinct from Appointment.sessionNotes (which is the doctor's
// free-text consult notes on the same appointment) — therapists
// document the four canonical SOAP fields plus session metadata, and
// optionally make each note visible to the patient's doctor for
// hand-off context.
model TherapistSessionNote {
  id            String       @id @default(cuid())
  therapistId   String
  therapist     Therapist    @relation(fields: [therapistId], references: [id])
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  // SOAP — Subjective, Objective, Assessment, Plan. All nullable so a
  // therapist can save a partial draft and finish later.
  subjective String?
  objective  String?
  assessment String?
  plan       String?

  // Session metadata. sessionType is a free-form string so the surface
  // can evolve without schema churn (typical values: INDIVIDUAL, GROUP,
  // HOME_THERAPY).
  sessionType     String?
  duration        Int? // minutes
  nextSessionPlan String?

  // Visibility toggle — when false, only the authoring therapist (and
  // admin roles) can read this note. The patient-timeline endpoint
  // filters on this for non-author readers.
  isVisibleToDoctor Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([therapistId])
  @@index([patientId])
  @@index([appointmentId])
  @@index([patientId, isVisibleToDoctor])
  @@index([therapistId, patientId])
}

// Structured per-session therapy outcomes — the therapist's
// quantifiable counterpart to TherapistSessionNote (SOAP free text).
// Doctors trend pain / mobility / swelling across sessions on the
// patient timeline; therapists log one row per delivered sitting.
//
// All score fields are nullable so partial entries are valid (e.g.
// the therapist captures pain + observation but no mobility test).
model TherapyOutcome {
  id                    String       @id @default(cuid())
  therapistId           String
  therapist             Therapist    @relation(fields: [therapistId], references: [id])
  patientId             String
  patient               Patient      @relation(fields: [patientId], references: [id])
  appointmentId         String?
  appointment           Appointment? @relation(fields: [appointmentId], references: [id])
  sessionDate           DateTime     @db.Date
  mobilityScore         Int?
  painScore             Int?
  swellingReduced       Boolean?
  functionalImprovement String?
  therapistObservation  String?
  nextSessionGoal       String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @default(now()) @updatedAt

  @@index([patientId, sessionDate])
  @@index([therapistId])
  @@index([appointmentId])
}

