  doctor       Doctor?     @relation(fields: [doctorId], references: [id])
  patient      Patient     @relation(fields: [patientId], references: [id])
  therapist    Therapist?  @relation(fields: [therapistId], references: [id])
  pharmacist   Pharmacist? @relation(fields: [pharmacistId], references: [id])
  messages     Message[]
  branch       Branch?     @relation(fields: [branchId], references: [id])
  branchId     String?

  @@unique([patientId, doctorId])
  @@unique([patientId, therapistId])
  @@unique([patientId, pharmacistId])
  @@index([patientId])
  @@index([doctorId])
  @@index([therapistId])
  @@index([pharmacistId])
  @@index([branchId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt]) // Composite covers single-column conversationId queries
  @@index([createdAt])
}

// ─── Staff messaging (DMs + branch group chats) ──────────────────────────
// Separate from the patient-clinician `Conversation` table so the polymorphic
// thread shape (1-on-1 staff DM vs. multi-member group) doesn't pollute the
// existing patient chat domain. Tenancy isolation via `hospitalId` is
// enforced in the service layer on every read/write.

enum StaffThreadKind {
  DIRECT
  GROUP
}

enum StaffThreadMemberRole {
  OWNER // group creator
  ADMIN // can add/remove members (admin doctor auto-included as ADMIN)
  MEMBER // can read/write only
}

enum StaffMessageKind {
  TEXT
  SYSTEM // "Alice was added by Bob" — sender may be null
}

model StaffThread {
  id          String          @id @default(uuid())
  kind        StaffThreadKind
  // Display name for groups; null for DIRECT (rendered from the partner's name).
  title       String?
  hospitalId  String
  // Optional branch scope for groups. Cross-branch DMs leave it null.
  branchId    String?
  // Sorted-pair key for DIRECT threads ("uidA:uidB" with uidA < uidB).
  // Null for GROUP. Unique index dedupes DMs at the DB level.
  directKey   String?         @unique
  createdById String
  archivedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  hospital  Hospital            @relation(fields: [hospitalId], references: [id])
  branch    Branch?             @relation(fields: [branchId], references: [id])
  createdBy User                @relation("StaffThreadCreator", fields: [createdById], references: [id])
  members   StaffThreadMember[]
  messages  StaffMessage[]

  @@index([hospitalId])
  @@index([branchId])
  @@index([kind])
  @@index([updatedAt])
}

model StaffThreadMember {
  id             String                @id @default(uuid())
  threadId       String
  userId         String
  role           StaffThreadMemberRole @default(MEMBER)
  // True for admin doctors auto-included on group creation. The flag prevents
  // group OWNERs from removing oversight members; only system ADMIN can.
  isAutoIncluded Boolean               @default(false)
  joinedAt       DateTime              @default(now())
  // Used for unread-count math: messages with createdAt > lastReadAt count.
  lastReadAt     DateTime?
  // Soft-remove so we can show a complete history audit. Excluded from active
  // member lists and message broadcast.
  removedAt      DateTime?
  addedById      String?

  thread  StaffThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user    User        @relation("StaffThreadMembership", fields: [userId], references: [id])
  addedBy User?       @relation("StaffMemberAddedBy", fields: [addedById], references: [id])

  @@unique([threadId, userId])
  @@index([userId, removedAt])
  @@index([threadId, removedAt])
}

model StaffMessage {
  id        String           @id @default(uuid())
  threadId  String
  // Null for SYSTEM messages (member-add / member-remove notices).
  senderId  String?
  kind      StaffMessageKind @default(TEXT)
  content   String
  editedAt  DateTime?
  // Soft delete — UI renders a tombstone "message removed" so threading reads
  // still make sense after a deletion.
  deletedAt DateTime?
  createdAt DateTime         @default(now())

  thread StaffThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User?       @relation("StaffMessageSender", fields: [senderId], references: [id])

  @@index([threadId, createdAt])
}

enum Role {
  SUPER_ADMIN
  ADMIN_DOCTOR
  DOCTOR
  THERAPIST
  PATIENT
  ADMIN
  PHARMACIST
  BRANCH_ADMIN
}

enum ConsultationType {
  DOCTOR
  THERAPIST
  COMBINED
}

model LeaderboardConfig {
  id                 String   @id @default(uuid())
  appointmentWeight  Float    @default(0.2)
  adherenceWeight    Float    @default(0.2)
  responseTimeWeight Float    @default(0.2)
  successRateWeight  Float    @default(0.2)
  consistencyWeight  Float    @default(0.2)
  targetAppointments Int      @default(50)
  targetAdherence    Float    @default(90.0)
  targetSuccessRate  Float    @default(80.0)
  targetResponseTime Float    @default(30.0) // minutes
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model FeatureFlag {
  id              String   @id @default(uuid())
  key             String   @unique
  enabled         Boolean  @default(false)
  description     String?
  allowedRoles    String[]
  allowedBranches String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([key])
}

model RefillRequest {
  id             String       @id @default(uuid())
  prescriptionId String
  patientId      String
  requestedById  String
  status         String       @default("PENDING") // PENDING | APPROVED | REJECTED | FULFILLED
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  patient        Patient      @relation(fields: [patientId], references: [id])
  requestedBy    User         @relation(fields: [requestedById], references: [id])

  @@index([prescriptionId])
  @@index([patientId])
  @@index([status])
  @@index([requestedById])
}

model Referral {
  id            String   @id @default(uuid())
  referrerId    String
  referredId    String?
  referralCode  String   @unique
  status        String   @default("PENDING") // PENDING | REGISTERED | COMPLETED
  rewardGranted Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  referrer      Patient  @relation("PatientReferrals", fields: [referrerId], references: [id])
  referred      Patient? @relation("PatientReferredBy", fields: [referredId], references: [id])

  @@index([referrerId])
  @@index([referralCode])
  @@index([status])
}

model LeaderboardAudit {
  id              String   @id @default(uuid())
  participantId   String
  participantRole Role
  score           Float
  metrics         Json // Stores the raw metrics used for calculation
  weights         Json // Stores the weights used for calculation
  sourceRecordIds Json? // Tracks the IDs of original records used in scoring
  integrityHash   String? // Hash of the data used for verification
  rank            Int?
  calculationDate DateTime @default(now())

  @@index([participantId])
  @@index([calculationDate])
}

// ── Retention Checklist ───────────────────────────────────────────────────────
// Recorded by a doctor or therapist at the end of (or during) a consultation
// to track patient adherence across five structured follow-up categories.

enum RetentionStatus {
  COMPLETED
  PARTIAL
  NOT_FOLLOWED
}

model RetentionChecklist {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  patientId     String
  clinicianId   String // userId of the recording doctor / therapist
  clinicianRole String // DOCTOR | THERAPIST | ADMIN_DOCTOR
  items         Json // Array<{ category: RetentionCategory, status: RetentionStatus, notes?: string }>
  branchId      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  patient       Patient     @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([appointmentId])
  @@index([clinicianId])
  @@index([branchId])
  @@index([clinicianId, createdAt]) // Leaderboard: active follow-up days per clinician
}

// ── Appointment Feedback (CSAT) ───────────────────────────────────────────────
// Submitted once by the patient after an appointment is COMPLETED.
// Clinicians and admins can view aggregated ratings.

model AppointmentFeedback {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  patientId     String
  rating        Int // 1–5
  comment       String?
  branchId      String?
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  patient       Patient     @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([appointmentId])
  @@index([branchId])
}

// ── Structured post-consultation feedback ────────────────────────────────────
// 4-question flow shown to the patient on their next app open after a doctor
// marks the consultation COMPLETED. Each positive response awards 1 XP to the
// doctor via ClinicianXPService (max 4 XP per submission). Stars live on
// AppointmentFeedback; this table captures the richer qualitative answers.

enum FeedbackMcqOption {
  A
  B
  C
  D
}

enum FeedbackSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

model ConsultationFeedback {
  id                  String             @id @default(cuid())
  appointmentId       String             @unique
  appointment         Appointment        @relation(fields: [appointmentId], references: [id])
  patientId           String
  patient             Patient            @relation(fields: [patientId], references: [id])
  doctorId            String?
  doctor              Doctor?            @relation(fields: [doctorId], references: [id])
  // Role-agnostic clinician reference for the new rating flow (DOCTOR/THERAPIST/ADMIN_DOCTOR).
  // doctorId remains for the legacy MCQ flow back-compat.
  clinicianId         String?
  clinicianRole       Role?
  branchId            String?
  branch              Branch?            @relation(fields: [branchId], references: [id])
  // Legacy MCQ flow fields (2026-04-24 release) — keep populated for old prompts.
  faceScaleEmotional  Int? // 1–5
  faceScaleConfidence Int? // 1–5
  mcqListening        FeedbackMcqOption?
  mcqReturn           FeedbackMcqOption?
  // New rating-based flow.
  rating              Int? // 1–5
  sentiment           FeedbackSentiment?
  categories          String[]           @default([])
  feedbackText        String?
  // Legacy MCQ-flow snapshot — total XP awarded by the 4-question flow (0..4).
  // Untouched by the new rating flow; renaming it would break in-flight data.
  xpAwarded           Int                @default(0)
  // New flag — has the rating-flow XP reward (75 XP for POSITIVE) been disbursed?
  // Separate from `xpAwarded` so both flows can coexist without aliasing.
  xpRewardClaimed     Boolean            @default(false)
  acknowledgedById    String?
  acknowledgedAt      DateTime?
  createdAt           DateTime           @default(now())
  completedAt         DateTime?

  @@index([doctorId])
  @@index([clinicianId])
  @@index([patientId])
  @@index([branchId])
  @@index([createdAt])
}

// 7-stage feedback experience triggered when a TreatmentJourney is marked
// COMPLETED. 1:1 with TreatmentJourney via UNIQUE(journeyId). Single
// submission only — once `completedAt` is set, the row is final.
model JourneyFeedback {
  id                 String           @id @default(cuid())
  journeyId          String           @unique
  journey            TreatmentJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  patientId          String
  patient            User             @relation("JourneyFeedbackPatient", fields: [patientId], references: [id])
  leadDoctorId       String
  leadDoctor         User             @relation("JourneyFeedbackLeadDoctor", fields: [leadDoctorId], references: [id])
  // Role-agnostic primary clinician for new rating flow. Mirrors leadDoctorId
  // for DOCTOR-led journeys; can point to a THERAPIST user for therapist-led ones.
  primaryClinicianId String?
  primaryClinician   User?            @relation("JourneyFeedbackPrimaryClinician", fields: [primaryClinicianId], references: [id])
  branchId           String?
  branch             Branch?          @relation("JourneyFeedbackBranch", fields: [branchId], references: [id])

  // 4 operational MCQs — each individually skippable (null = skipped)
  mcqAppointments         FeedbackMcqOption?
  mcqReminders            FeedbackMcqOption?
  mcqMedications          FeedbackMcqOption?
  mcqFamilyRecommendation FeedbackMcqOption?

  // Garden / growth metaphor — 5 levels (1, 3, 5, 7, 10)
  gardenScore         Int?
  // Face-of-care experience — 1-5
  faceScaleExperience Int?

  // Thank-you card (optional, free-form, max 2000 chars)
  thankYouCardText   String?
  thankYouCardPublic Boolean @default(false)

  photosViewed   Boolean @default(false)
  // Legacy XP snapshot (sum of distributed XP for the MCQ flow).
  // Untouched by the new rating flow.
  xpAwarded      Int     @default(0)
  xpDistribution Json    @default("{}")

  // ── New rating-based flow ─────────────────────────────────────────
  overallRating    Int?
  outcomeRating    Int?
  adherenceRating  Int?
  sentiment        FeedbackSentiment?
  highlights       String[]           @default([])
  feedbackText     String?
  wouldRecommend   Boolean?
  // Has the rating-flow XP reward (150 XP for POSITIVE) been disbursed?
  xpRewardClaimed  Boolean            @default(false)
  acknowledgedById String?
  acknowledgedAt   DateTime?

  // Spec: feedback remains available 30 days; silently closes after that.
  expiresAt      DateTime
  // 72h reminder push tracker (idempotency stamp).
  reminderSentAt DateTime?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  thankYouCard ThankYouCard?

  @@index([leadDoctorId])
  @@index([primaryClinicianId])
  @@index([patientId])
  @@index([branchId])
  @@index([completedAt])
  @@index([completedAt, reminderSentAt])
}

// Privacy-isolated thank-you note. Separate model so the doctor recognition
// panel can join only on visibility-allowed cards without leaking the rest
// of the feedback payload.
model ThankYouCard {
  id                String                 @id @default(cuid())
  feedbackId        String                 @unique
  feedback          JourneyFeedback        @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  recipientDoctorId String
  recipientDoctor   User                   @relation("ThankYouCardRecipient", fields: [recipientDoctorId], references: [id])
  content           String
  visibility        ThankYouCardVisibility @default(PRIVATE)
  createdAt         DateTime               @default(now())

  @@index([recipientDoctorId, visibility, createdAt])
}

enum ThankYouCardVisibility {
  PRIVATE
  PUBLIC
}

// ── Treatment Journey Engine ─────────────────────────────────────────────────
// Structured illness-to-wellness journey with phases, tasks, milestones, and vitals.

model TreatmentJourney {
  id             String             @id @default(cuid())
  patientId      String
  patient        User               @relation("JourneyPatient", fields: [patientId], references: [id])
  branchId       String
  branch         Branch             @relation(fields: [branchId], references: [id])
  doctorId       String
  doctor         User               @relation("JourneyDoctor", fields: [doctorId], references: [id])
  title          String
  condition      String
  startDate      DateTime           @default(now())
  targetDate     DateTime?
  status         JourneyStatus      @default(ACTIVE)
  phases         JourneyPhase[]
  milestones     JourneyMilestone[]
  vitals         PatientVital[]
  clinicalPhotos ClinicalPhoto[]
  appointments   Appointment[]      @relation("JourneyAppointments")
  feedback       JourneyFeedback?
  prescriptions  Prescription[]     @relation("JourneyPrescriptions")
  wellnessScore  Float              @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([branchId])
  @@index([status])
}

model JourneyPhase {
  id             String           @id @default(cuid())
  journeyId      String
  journey        TreatmentJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  name           String
  order          Int
  durationDays   Int              @default(7)
  status         PhaseStatus      @default(UPCOMING)
  tasks          PhaseTask[]
  clinicalPhotos ClinicalPhoto[]
  startedAt      DateTime?
  completedAt    DateTime?
  // Auto-generated end-of-phase progress reports (Feature 4)
  healthReports  HealthReport[]

  @@index([journeyId])
}

model PhaseTask {
  id          String           @id @default(cuid())
  phaseId     String
  phase       JourneyPhase     @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  type        TaskType
  title       String
  description String?
  frequency   String
  completions TaskCompletion[]

  @@index([phaseId])
}

model TaskCompletion {
  id          String    @id @default(cuid())
  taskId      String
  task        PhaseTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  patientId   String
  patient     User      @relation(fields: [patientId], references: [id])
  completedAt DateTime  @default(now())
  notes       String?
  mediaUrl    String?

  @@index([taskId])
  @@index([patientId])
}

model JourneyMilestone {
  id          String           @id @default(cuid())
  journeyId   String
  journey     TreatmentJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  title       String
  description String?
  targetDate  DateTime?
  achievedAt  DateTime?
  isAchieved  Boolean          @default(false)
  badgeIcon   String?

  @@index([journeyId])
}

model PatientVital {
  id         String            @id @default(cuid())
  journeyId  String?
  journey    TreatmentJourney? @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  patientId  String
  patient    User              @relation(fields: [patientId], references: [id])
  type       VitalType
  value      Float
  unit       String
  recordedAt DateTime          @default(now())
  source     String            @default("manual")

  @@index([journeyId])
  @@index([patientId])
  @@index([type, recordedAt])
}

// Vitals the doctor has prescribed a patient to track. Drives the
// Patient dashboard's vital tiles — only prescribed vitals are surfaced.
model PrescribedVital {
  id             String    @id @default(cuid())
  patientId      String // Patient.id (NOT User.id — billing/clinical scope)
  vitalType      VitalType
  frequency      String    @default("DAILY") // DAILY | WEEKLY | TWICE_DAILY
  notes          String? // Doctor's instruction (e.g. "Morning, fasting")
  active         Boolean   @default(true)
  prescribedById String // User.id of the prescribing doctor/admin-doctor
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescribedBy User    @relation("PrescribedVitalAuthor", fields: [prescribedById], references: [id])

  @@unique([patientId, vitalType])
  @@index([patientId, active])
  @@index([prescribedById])
}

enum JourneyStatus {
  ACTIVE
  COMPLETED
  PAUSED
  DISCONTINUED
}

enum PhaseStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  SKIPPED
}

enum TaskType {
  MEDICATION
  EXERCISE
  DIET
  THERAPY
  LIFESTYLE
}

enum VitalType {
  PAIN_SCORE
  WEIGHT
  BP_SYSTOLIC
  BP_DIASTOLIC
  GLUCOSE
  SLEEP_HOURS
  MOOD
}

// ── Gamification: Badges & Achievements ─────────────────────────────────────

enum BadgeTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model Badge {
  id          String      @id @default(cuid())
  code        String      @unique // "STREAK_7", "APPOINTMENTS_100", "FIRST_PERFECT_WEEK"
  name        String
  description String
  icon        String // lucide icon name
  tier        BadgeTier
  criteria    Json // { metric: "appointments", threshold: 100, type: "cumulative"|"streak"|"rate" }
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  awards      UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

// ── Gamification: Clinician Streaks ─────────────────────────────────────────

model ClinicianStreak {
  id                String    @id @default(cuid())
  participantId     String    @unique // Doctor or Therapist profile ID
  participantRole   Role
  currentStreak     Int       @default(0)
  longestStreak     Int       @default(0)
  lastActiveDate    DateTime?
  graceUsedThisWeek Boolean   @default(false) // 1 off-day allowed per week
  streakMultiplier  Float     @default(1.0) // Bonus multiplier for scoring
  updatedAt         DateTime  @updatedAt

  @@index([participantId])
}

// ── Gamification: Branch Competitions ───────────────────────────────────────

model BranchCompetition {
  id          String                   @id @default(cuid())
  title       String
  description String?
  metric      String // "avgScore" | "avgResponseTime" | "totalAppointments"
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean                  @default(true)
  createdById String
  createdBy   User                     @relation("CompetitionCreator", fields: [createdById], references: [id])
  entries     BranchCompetitionEntry[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([isActive, endDate])
}

model BranchCompetitionEntry {
  id            String            @id @default(cuid())
  competitionId String
  competition   BranchCompetition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  branchId      String
  branch        Branch            @relation(fields: [branchId], references: [id])
  score         Float             @default(0)
  rank          Int?
  updatedAt     DateTime          @updatedAt

  @@unique([competitionId, branchId])
  @@index([competitionId])
  @@index([branchId])
}

// ── Gamification: Daily Challenges (Patient-facing) ─────────────────────────

model DailyChallenge {
  id          String                       @id @default(cuid())
  title       String
  description String
  type        String // "VITAL_LOG" | "TASK_COMPLETE" | "CHECKIN" | "EXERCISE"
  pointReward Int                          @default(10)
  activeDate  DateTime // The date this challenge is active for
  createdAt   DateTime                     @default(now())
  completions PatientChallengeCompletion[]

  @@index([activeDate])
}

model PatientChallengeCompletion {
  id          String         @id @default(cuid())
  patientId   String
  patient     Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  completedAt DateTime       @default(now())

  @@unique([patientId, challengeId])
  @@index([patientId])
}

// ── Gamification: Zen Points Ledger (Patient) ───────────────────────────────

model ZenPointsLedger {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  action    String // "TASK_COMPLETION" | "VITAL_LOG" | "APPOINTMENT_ATTENDANCE" | "STREAK_BONUS" | "MILESTONE" | "CHALLENGE"
  points    Int
  sourceId  String? // ID of the task/appointment/etc that triggered this
  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([patientId, createdAt])
  @@index([action])
}

// ── Gamification: Patient Streaks ───────────────────────────────────────────

model PatientStreak {
  id             String    @id @default(cuid())
  patientId      String    @unique
  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime?
  updatedAt      DateTime  @updatedAt

  @@index([patientId])
}

// ── F04 · Predictive Dosha Imbalance Engine ─────────────────────────────────
// One row per nightly forecast run that exceeded the alert threshold for a
// patient. The cron writes through this table BEFORE upserting into
// PatientCriticalFlag so we have a versioned history of predictions — the
// PatientCriticalFlag carries the live state, this table carries the audit
// trail of what was predicted when.
model DoshaForecast {
  id              String    @id @default(cuid())
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  generatedAt     DateTime  @default(now())
  daysUntilSymp   Int
  confidence      Float
  // VATA | PITTA | KAPHA — kept as String (not enum) since archetypes are
  // expected to evolve as the scoring engine matures.
  dominantDosha   String
  // AGGRAVATION | DEPLETION (only AGGRAVATION fires today; depletion rules
  // are placeholder for future work).
  imbalanceType   String
  triggerFactors  String[]
  alertEmitted    Boolean   @default(false)
  alertEmittedAt  DateTime?
  resolved        Boolean   @default(false)
  resolvedAt      DateTime?

  @@index([patientId, generatedAt])
}

// ── F05 · Behavioural Nudge Engine ──────────────────────────────────────────
// One row per outbound nudge produced by the LLM-driven nudge generator that
// replaces the static motivation template when the BEHAVIOURAL_NUDGE_ENGINE
// flag is on for the patient's hospital. The check-in feedback loop stamps
// checkInCompleted/checkInAt when the patient submits a daily check-in within
// the message window, which is what later analytics will use to score which
// archetype actually drives engagement.
model NudgeLog {
  id               String    @id @default(cuid())
  patientId        String
  patient          Patient   @relation(fields: [patientId], references: [id])
  sentAt           DateTime  @default(now())
  // STREAK_MOTIVATED | PROGRESS_MOTIVATED | SOCIAL_MOTIVATED | LOSS_AVERSE
  // (kept as String — adding an enum here would slow future tuning since
  // archetypes are expected to evolve as we learn engagement patterns.)
  archetype        String
  messageText      String
  checkInCompleted Boolean   @default(false)
  checkInAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([patientId, sentAt])
}

// ── Gamification: Anti-Gaming Audit ─────────────────────────────────────────

model GamificationAnomaly {
  id              String   @id @default(cuid())
  participantId   String
  participantRole Role
  anomalyType     String // "SCORE_SPIKE" | "RATE_LIMIT_EXCEEDED" | "SUSPICIOUS_PATTERN"
  details         Json // { previousScore, newScore, stdDeviation, etc }
  resolved        Boolean  @default(false)
  resolvedBy      String?
  createdAt       DateTime @default(now())

  @@index([participantId])
  @@index([anomalyType])
  @@index([resolved])
}

// ── Gamification: Adaptive Targets ──────────────────────────────────────────

model AdaptiveTarget {
  id               String    @id @default(cuid())
  participantId    String
  participantRole  Role
  metric           String // "appointments" | "adherence" | "responseTime" | "successRate"
  personalTarget   Float
  baseTarget       Float // From LeaderboardConfig at time of calculation
  adjustmentReason String? // "progressive_increase" | "part_time_adjustment" | "percentile_based"
  effectiveFrom    DateTime  @default(now())
  effectiveUntil   DateTime?
  createdAt        DateTime  @default(now())

  @@unique([participantId, metric, effectiveFrom])
  @@index([participantId])
  @@index([effectiveFrom])
}

// ══════════════════════════════════════════════════════════════════════════════
// NEW FEATURES — Resource Sharing, Inventory, Staff, Gamification v2, Portal
// ══════════════════════════════════════════════════════════════════════════════

// ── Feature 4: Resource Sharing (Cross-Branch Doctor Coverage) ──────────────

model ResourceSharing {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation("SharedStaff", fields: [userId], references: [id], onDelete: Cascade)
  fromBranchId String
  fromBranch   Branch        @relation("SharingFrom", fields: [fromBranchId], references: [id], onDelete: Cascade)
  toBranchId   String
  toBranch     Branch        @relation("SharingTo", fields: [toBranchId], references: [id], onDelete: Cascade)
  // `date` is the start date. `endDate` was added so the form can capture
  // a true date range; nullable so back-fill of legacy rows is a no-op.
  date         DateTime
  endDate      DateTime?
  startTime    String
  endTime      String
  status       SharingStatus @default(PENDING)
  reason       String?
  approvedBy   String?
  // The user that created this request — used for "creator can edit/delete
  // their own pending request" gating. Nullable for legacy rows.
  createdById  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([date])
