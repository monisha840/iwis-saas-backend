  body          String?
  templateId    String?
  template      MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now())

  @@index([hospitalId, kind])
  @@index([appointmentId])
  @@index([patientUserId])
  @@index([createdAt])
}

// ── Follow-up schedule + Critical Journey flagging ─────────────────────
// Enforces the clinical workflow where every completed consultation must
// have a follow-up decision (schedule N days out OR single-visit). The
// CriticalJourney detector watches for non-adherence (missed meds, missed
// vital uploads, missed follow-ups) and surfaces at-risk patients to the
// admin dashboard with specific reasons.

enum FollowUpInterval {
  SEVEN_DAYS
  FOURTEEN_DAYS
  THIRTY_DAYS
  SIXTY_DAYS
  NINETY_DAYS
  CUSTOM
  SINGLE_VISIT
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  MISSED
  CANCELLED
}

enum CriticalStatus {
  ACTIVE
  RESOLVED
}

model AppointmentFollowUp {
  id                       String           @id @default(cuid())
  appointmentId            String           @unique
  appointment              Appointment      @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patientId                String
  patient                  Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  // Preset interval OR CUSTOM (with daysOffset) OR SINGLE_VISIT (no due date)
  interval                 FollowUpInterval
  daysOffset               Int?
  dueDate                  DateTime?
  isSingleVisit            Boolean          @default(false)
  status                   FollowUpStatus   @default(PENDING)
  notes                    String?
  // Clinician who set the follow-up (ADMIN / ADMIN_DOCTOR / DOCTOR / THERAPIST)
  createdById              String
  createdBy                User             @relation("FollowUpCreator", fields: [createdById], references: [id])
  // If the patient booked a subsequent visit that fulfilled this follow-up
  completedByAppointmentId String?
  // Dedup guard for the "missed follow-up" cron
  missedNotifiedAt         DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([patientId, status])
  @@index([dueDate, status])
  @@index([status])
  @@index([createdById])
}

// One row per patient (unique) — upsert-based. The reasons JSON holds an
// array of {type, detail, firstDetectedAt, lastDetectedAt, value?}.
// Detector overwrites the list every run; status transitions are audited
// via resolvedAt / resolvedById.
model PatientCriticalFlag {
  id              String         @id @default(cuid())
  patientId       String         @unique
  patient         Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  branchId        String?
  branch          Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  status          CriticalStatus @default(ACTIVE)
  severity        String         @default("MEDIUM") // LOW | MEDIUM | HIGH
  reasons         Json           @default("[]")
  firstDetectedAt DateTime       @default(now())
  lastDetectedAt  DateTime       @default(now())
  resolvedAt      DateTime?
  resolvedById    String?
  resolvedBy      User?          @relation("CriticalFlagResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status, lastDetectedAt])
  @@index([branchId, status])
  @@index([severity, status])
}

// ── Home Therapy ─────────────────────────────────────────────────────────────
// Doctor authors a HomeTherapyRequest during prescription. Admin / branch-admin
// approves, assigns a therapist, and schedules N sessions. Each session is
// either HOME (therapist visits patient's address — GPS-tracked) or HOSPITAL
// (existing in-clinic flow). On approval, one Appointment per session is also
// created so existing reminder / feedback / billing pipelines work unchanged.
enum HomeTherapyStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SessionModeType {
  HOME
  HOSPITAL
}

enum HomeTherapySessionStatus {
  SCHEDULED
  THERAPIST_EN_ROUTE
  THERAPIST_ARRIVED
  IN_SESSION
  COMPLETED
  CANCELLED
  NO_SHOW
}

model HomeTherapyRequest {
  id                 String            @id @default(cuid())
  prescriptionId     String
  prescription       Prescription      @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  patientId          String
  patient            Patient           @relation(fields: [patientId], references: [id])
  requestingDoctorId String
  requestingDoctor   Doctor            @relation(fields: [requestingDoctorId], references: [id])
  branchId           String
  branch             Branch            @relation(fields: [branchId], references: [id])
  totalSessions      Int
  sessionMode        SessionModeType[] @default([])
  // Optional scheduling interval between sessions, in days. Set by the
  // doctor on the prescription form when the protocol calls for spacing
  // (e.g. 1 = daily, 2 = every other day, 7 = weekly). Null when no
  // interval is specified — admin uses their judgement during approval.
  intervalDays       Int?
  notes              String?
  status             HomeTherapyStatus @default(PENDING_APPROVAL)
  approvedById       String?
  approvedByRole     Role?
  approvedAt         DateTime?
  rejectedReason     String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  sessions HomeTherapySession[]

  @@index([patientId])
  @@index([requestingDoctorId])
  @@index([branchId, status])
  @@index([status, createdAt])
}

model HomeTherapySession {
  id                  String                   @id @default(cuid())
  requestId           String
  request             HomeTherapyRequest       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  therapistId         String
  therapist           Therapist                @relation(fields: [therapistId], references: [id])
  patientId           String
  patient             Patient                  @relation(fields: [patientId], references: [id])
  branchId            String
  sessionNumber       Int
  scheduledDate       DateTime
  scheduledTime       String
  mode                SessionModeType
  status              HomeTherapySessionStatus @default(SCHEDULED)
  therapistDepartedAt DateTime?
  therapistArrivedAt  DateTime?
  sessionStartedAt    DateTime?
  sessionCompletedAt  DateTime?
  therapistFeedbackId String?                  @unique
  patientFeedbackId   String?                  @unique
  appointmentId       String?                  @unique
  appointment         Appointment?             @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  locationPings     TherapistLocationPing[]
  therapistFeedback HomeTherapyFeedback?    @relation("therapistFeedback", fields: [therapistFeedbackId], references: [id])
  patientFeedback   HomeTherapyFeedback?    @relation("patientFeedback", fields: [patientFeedbackId], references: [id])

  @@index([therapistId, scheduledDate])
  @@index([patientId, scheduledDate])
  @@index([branchId, scheduledDate])
  @@index([status, scheduledDate])
  @@index([requestId, sessionNumber])
}

model TherapistLocationPing {
  id          String             @id @default(cuid())
  sessionId   String
  session     HomeTherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  therapistId String
  latitude    Float
  longitude   Float
  accuracy    Float?
  timestamp   DateTime           @default(now())

  @@index([sessionId, timestamp])
  @@index([therapistId, timestamp])
}

model HomeTherapyFeedback {
  id         String            @id @default(cuid())
  sessionId  String
  authorRole Role
  rating     Int
  sentiment  FeedbackSentiment
  notes      String?
  tags       String[]          @default([])
  xpAwarded  Boolean           @default(false)
  createdAt  DateTime          @default(now())

  therapistSession HomeTherapySession? @relation("therapistFeedback")
  patientSession   HomeTherapySession? @relation("patientFeedback")

  @@index([sessionId])
  @@index([authorRole, createdAt])
}

// ── Ayurvedic Voice Health Coach (AYURVEDIC_VOICE_COACH feature) ─────────────
// Each VoiceConversation is one back-and-forth coaching session, scoped to a
// single Patient. A turn is a VoiceMessage. Conversations stay open across
// brief disconnects (resume window handled at the service layer); endedAt is
// set when the patient explicitly closes the session or the resume window
// expires. Audio is not persisted by default — see plan §8.

model VoiceConversation {
  id             String         @id @default(cuid())
  patientId      String
  patient        Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  language       String // 'ta' | 'en'
  startedAt      DateTime       @default(now())
  endedAt        DateTime?
  turnCount      Int            @default(0)
  escalated      Boolean        @default(false)
  escalationNote String?
  sessionSummary String?
  createdAt      DateTime       @default(now())
  messages       VoiceMessage[]

  @@index([patientId, createdAt(sort: Desc)])
  @@index([escalated])
}

model VoiceMessage {
  id              String            @id @default(cuid())
  conversationId  String
  conversation    VoiceConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            VoiceRole
  transcript      String
  audioStorageKey String?
  detectedIntent  String? // MEDICATION_QUERY | SYMPTOM_REPORT | LIFESTYLE | EMERGENCY | GENERAL | BOOKING_REQUEST
  severityFlag    String? // LOW | MEDIUM | HIGH | CRITICAL
  createdAt       DateTime          @default(now())

  @@index([conversationId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Ayurvedic Food Database + Recipe Library (Feature 1)
//
// Branch-scoped catalogue of foods (with dosha effects, rasa/guna metadata,
// nutrition + allergy hints) and reusable recipes built from them. The
// `DietMealFoodLink` join table lets a clinician attach structured food
// rows to an existing DietMeal in addition to (or instead of) the legacy
// free-text JSON columns. Patient-side surfaces fall through to free-text
// when no structured links exist for a meal.
// ─────────────────────────────────────────────────────────────────────────────

enum FoodCategory {
  GRAIN
  VEGETABLE
  FRUIT
  DAIRY
  SPICE
  OIL
  LEGUME
  MEAT
  HERB
  BEVERAGE
  OTHER
}

enum RasaType {
  SWEET
  SOUR
  SALTY
  PUNGENT
  BITTER
  ASTRINGENT
}

enum GunaType {
  HEAVY
  LIGHT
  OILY
  DRY
  HOT
  COLD
  SHARP
  SOFT
  STABLE
  MOBILE
}

enum Season {
  WINTER
  SUMMER
  MONSOON
  AUTUMN
  SPRING
}

model AyurvedicFood {
  id                 String       @id @default(cuid())
  name               String
  nameInTamil        String?
  nameInSanskrit     String?
  category           FoodCategory
  // Per-dosha effect: PACIFYING | NEUTRAL | AGGRAVATING (kept as String
  // not enum so future tiers can be added without a migration).
  doshaEffectVata    String       @default("NEUTRAL")
  doshaEffectPitta   String       @default("NEUTRAL")
  doshaEffectKapha   String       @default("NEUTRAL")
  rasa               RasaType[]
  guna               GunaType[]
  // Energy direction (heating vs cooling). HOT | COLD | NEUTRAL.
  virya              String       @default("NEUTRAL")
  seasons            Season[]
  preparationMethods String[]
  calories           Float?
  protein            Float?
  carbs              Float?
  fat                Float?
  fiber              Float?
  // Common allergens this food contains (e.g. NUTS, DAIRY, GLUTEN).
  // Compared against Patient.allergies during conflict-check.
  commonAllergies    String[]
  isActive           Boolean      @default(true)
  branchId           String
  branch             Branch       @relation("BranchAyurvedicFoods", fields: [branchId], references: [id])
  createdById        String
  createdBy          User         @relation("UserCreatedFoods", fields: [createdById], references: [id])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  recipeIngredients RecipeIngredient[]
  mealFoodLinks     DietMealFoodLink[]

  @@index([branchId, isActive])
  @@index([category])
}

model AyurvedicRecipe {
  id              String   @id @default(cuid())
  name            String
  nameInTamil     String?
  description     String?
  // Doshas this recipe targets (any of VATA/PITTA/KAPHA/TRIDOSHA).
  // Stored as String[] not enum because TRIDOSHA + multi-target are
  // common and we want callers to pick freely.
  doshaTargets    String[]
  prepTimeMinutes Int      @default(0)
  cookTimeMinutes Int      @default(0)
  servings        Int      @default(2)
  instructions    String[]
  // BREAKFAST | LUNCH | DINNER | SNACK | BEVERAGE | GENERAL
  mealCategory    String   @default("GENERAL")
  imageUrl        String?
  isActive        Boolean  @default(true)
  branchId        String
  branch          Branch   @relation("BranchRecipes", fields: [branchId], references: [id])
  createdById     String
  createdBy       User     @relation("UserCreatedRecipes", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ingredients RecipeIngredient[]

  @@index([branchId, isActive])
  @@index([mealCategory])
}

model RecipeIngredient {
  id        String          @id @default(cuid())
  recipeId  String
  recipe    AyurvedicRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  foodId    String
  food      AyurvedicFood   @relation(fields: [foodId], references: [id])
  quantity  Float
  unit      String
  notes     String?
  sortOrder Int             @default(0)

  @@index([recipeId, sortOrder])
}

model DietMealFoodLink {
  id           String         @id @default(cuid())
  mealId       String
  meal         DietMeal       @relation(fields: [mealId], references: [id], onDelete: Cascade)
  // Either structured (foodId) OR free-text (foodNameFree). At least one
  // must be set — service layer enforces.
  foodId       String?
  food         AyurvedicFood? @relation(fields: [foodId], references: [id])
  foodNameFree String?
  quantity     Float?
  unit         String?
  notes        String?
  // When true this is an "avoid" food rather than a recommended one.
  isAvoid      Boolean        @default(false)
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())

  @@index([mealId, isAvoid, sortOrder])
}

enum VoiceRole {
  USER
  ASSISTANT
  SYSTEM
}

// ──────────────────────────────────────────────────────────────────────────────
// Feature 2 — Ayurvedic PDF Health Report + WhatsApp Delivery
//
// One row per generated report. Snapshots the full assembled payload in
// `reportData` so the historical view stays stable even if upstream models
// change. The PDF itself lives on disk under `uploads/health-reports/`;
// `pdfPath` holds a relative path. Branch is denormalised so branch admins
// can scope queries without joining through Patient.
// ──────────────────────────────────────────────────────────────────────────────
model HealthReport {
  id            String       @id @default(cuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        Doctor       @relation(fields: [doctorId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  branchId      String
  branch        Branch       @relation(fields: [branchId], references: [id])

  // Discriminator added in Feature 4 — one of:
  //   "CONSULTATION"    (Feature 2 — branded post-visit PDF)
  //   "PHASE_PROGRESS"  (Feature 4 — end-of-phase progress summary)
  // Existing rows keep CONSULTATION via the default.
  reportType     String        @default("CONSULTATION")
  // Optional link to the JourneyPhase this report summarises. NULL for
  // CONSULTATION reports. Populated for PHASE_PROGRESS reports.
  journeyPhaseId String?
  journeyPhase   JourneyPhase? @relation(fields: [journeyPhaseId], references: [id])

  reportData   Json
  pdfPath      String?
  pdfSizeBytes Int?

  sentViaWhatsApp Boolean   @default(false)
  whatsappSentAt  DateTime?
  viewedByPatient Boolean   @default(false)
  viewedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, createdAt])
  @@index([doctorId])
  @@index([appointmentId])
  @@index([branchId])
  @@index([journeyPhaseId])
  @@index([reportType])
}

// ──────────────────────────────────────────────────────────────────────────────
// Feature 5 — Follow-Up Task Management
//
// Auto-generated by clinical events (triage swelling/high-pain, post-consult
// high-pain vital, low diet adherence, journey phase activation). Doctors
// see these in a morning panel on their dashboard; completing one earns XP.
//
// Idempotency: createFollowUpTask short-circuits when a PENDING/IN_PROGRESS
// task with the same (triggerType, triggerRef) already exists, so the four
// fire-and-forget hooks can safely re-fire without spawning duplicates.
// ──────────────────────────────────────────────────────────────────────────────
model FollowUpTask {
  id        String  @id @default(cuid())
  doctorId  String
  doctor    Doctor  @relation(fields: [doctorId], references: [id])
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  title       String
  description String?
  priority    TaskPriority       @default(MEDIUM)
  status      FollowUpTaskStatus @default(PENDING)
  dueDate     DateTime

  // Discriminator for what triggered the task — see followUpTask.service.js
  // for the canonical list. "MANUAL" is the doctor-authored variant.
  triggerType String
  // Source-record id (e.g. TriageSession.id, Appointment.id, JourneyPhase.id,
  // DietPrescription.id). Null for MANUAL tasks.
  triggerRef  String?

  completedAt    DateTime?
  completionNote String?
  xpAwarded      Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId, status, dueDate])
  @@index([doctorId, status, priority])
  @@index([patientId])
  @@index([triggerType, triggerRef])
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

// Status enum for FollowUpTask (Feature 5). Note: a separate `FollowUpStatus`
// enum already exists for the unrelated AppointmentFollowUp model — these two
// types intentionally diverge (this one adds IN_PROGRESS / DISMISSED).
enum FollowUpTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DISMISSED
}

// ──────────────────────────────────────────────────────────────────────────────
// Feature 3 — Workflow Automation Rules Engine
//
// Branch admins author no-code rules that fire on a schedule (or on certain
// clinical events). Each rule has:
//   - a triggerType (NO_CHECKIN, PAIN_NOT_IMPROVING, ...)
//   - a conditionValue JSON (e.g. { days: 3 })
//   - an actions JSON array (SEND_WHATSAPP, SEND_IN_APP, CREATE_FOLLOW_UP_TASK,
//     FLAG_FOR_DOCTOR), each with its own message template.
//
// The hourly cron-driven engine (workflowEngine.service.js) evaluates every
// active rule against patients in the rule's branch, executes the actions
// for matching patients, and writes a WorkflowCooldown row so the same rule
// won't fire for the same patient within `cooldownHours`.
// ──────────────────────────────────────────────────────────────────────────────
model WorkflowRule {
  id          String  @id @default(cuid())
  branchId    String
  branch      Branch  @relation(fields: [branchId], references: [id])
  name        String
  description String?
  isActive    Boolean @default(true)

  // One of: NO_CHECKIN | PAIN_NOT_IMPROVING | DIET_ADHERENCE_LOW |
  // PHASE_OVERDUE | PRESCRIPTION_UNCOLLECTED | PHASE_COMPLETED.
  // PHASE_COMPLETED is event-based (fired from journey routes) — the hourly
  // cron skips it.
  triggerType    String
  // Shape varies by triggerType — see workflowEngine.service.js for the schema.
  conditionValue Json
  // Array of action objects: see service for the per-type shape.
  actions        Json

  cooldownHours   Int       @default(48)
  totalFired      Int       @default(0)
  lastEvaluatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Cascading children: dropping a rule cleans up its history + cooldowns
  // so admins can re-create with the same name without stale state.
  logs      WorkflowRuleLog[]
  cooldowns WorkflowCooldown[]

  @@index([branchId, isActive])
  @@index([triggerType])
}

model WorkflowRuleLog {
  id           String       @id @default(cuid())
  ruleId       String
  rule         WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  patientId    String
  patient      Patient      @relation(fields: [patientId], references: [id])
  triggeredAt  DateTime     @default(now())
  // Per-action results: [{ "type": "SEND_WHATSAPP", "success": true }, ...].
  actionsTaken Json

  @@index([ruleId, triggeredAt])
  @@index([patientId])
}

model WorkflowCooldown {
  id          String       @id @default(cuid())
  ruleId      String
  rule        WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  patientId   String
  patient     Patient      @relation(fields: [patientId], references: [id])
  lastFiredAt DateTime     @default(now())

  @@unique([ruleId, patientId])
  @@index([ruleId])
}

// ── Daily tracking logs (Sheizen-inspired wellness surfaces) ───────────────
// One row per patient action, mounted under /api/daily-tracking/*.
// `date` is a midnight-stamped DateTime used for same-day filtering;
// `loggedAt` is the precise timestamp shown in the UI.

model WaterIntakeLog {
  id        String   @id @default(uuid())
  patientId String
  amount    Int
  loggedAt  DateTime
  date      DateTime
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId, date])
  @@index([patientId, loggedAt])
}

model ActivityLog {
  id               String   @id @default(uuid())
  patientId        String
  activityType     String
  durationMins     Int
  notes            String?
  loggedAt         DateTime
  date             DateTime
  zenPointsAwarded Int      @default(0)
  createdAt        DateTime @default(now())
  patient          Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId, date])
  @@index([patientId, loggedAt])
}

model BodyMeasurementLog {
  id        String   @id @default(uuid())
  patientId String
  arm       Float?
  chest     Float?
  waist     Float?
  hip       Float?
  thigh     Float?
  weight    Float?
  notes     String?
  loggedAt  DateTime
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId, loggedAt])
}

model MealPhotoLog {
  id        String   @id @default(uuid())
  patientId String
  mealType  String
  photoPath String
  photoUrl  String?
  notes     String?
  loggedAt  DateTime
  date      DateTime
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId, date])
}

// ── Monday Motivation Card ────────────────────────────────────────────────
// One Ayurvedic tip per patient per day. Cron at 10:00 IST every Monday
// generates a row for every onboarded patient (and WhatsApps it); dashboard
// load lazy-creates a row for patients onboarded mid-week.
// `prakriti` is one of VATA / PITTA / KAPHA / GENERAL.
// `season` is one of HEMANTA / SHISHIRA / VASANTA / GRISHMA / VARSHA / SHARAD.

model DailyMotivationCard {
  id             String    @id @default(uuid())
  patientId      String
  tip            String
  prakriti       String
  season         String
  date           DateTime
  isRead         Boolean   @default(false)
  readAt         DateTime?
  isSaved        Boolean   @default(false)
  savedAt        DateTime?
  whatsappSentAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  patient        Patient   @relation(fields: [patientId], references: [id])

  @@unique([patientId, date])
  @@index([patientId, isSaved])
}
